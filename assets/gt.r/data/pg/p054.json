[{"s":3,"n":30,"t":"\u064a\u064e\u0648\u0652\u0645\u064e \u062a\u064e\u062c\u0650\u062f\u064f \u0643\u064f\u0644\u0651\u064f \u0646\u064e\u0641\u0652\u0633\u064d\u06e2 \u0645\u0651\u064e\u0627 \u0639\u064e\u0645\u0650\u0644\u064e\u062a\u0652 \u0645\u0650\u0646\u0652 \u062e\u064e\u064a\u0652\u0631\u064d\u06e2 \u0645\u0651\u064f\u062d\u0652\u0636\u064e\u0631\u064b\u06ed\u0627 \u0648\u064e\u0645\u064e\u0627 \u0639\u064e\u0645\u0650\u0644\u064e\u062a\u0652 \u0645\u0650\u0646 \u0633\u064f\u0648\u0653\u0621\u064d\u06e2 \u062a\u064e\u0648\u064e\u062f\u0651\u064f \u0644\u064e\u0648\u0652 \u0623\u064e\u0646\u0651\u064e \u0628\u064e\u064a\u0652\u0646\u064e\u0647\u064e\u0627 \u0648\u064e\u0628\u064e\u064a\u0652\u0646\u064e\u0647\u064f\u06e5\u0653 \u0623\u064e\u0645\u064e\u062f\u064b\u06e2\u0627 \u0628\u064e\u0639\u0650\u064a\u062f\u064b\u06ed\u0627 \u06d7 \u0648\u064e\u064a\u064f\u062d\u064e\u0630\u0651\u0650\u0631\u064f\u0643\u064f\u0645\u064f \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0646\u064e\u0641\u0652\u0633\u064e\u0647\u064f\u06e5 \u06d7 \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0631\u064e\u0621\u064f\u0648\u0641\u064c\u06e2 \u0628\u0650\u0671\u0644\u0652\u0639\u0650\u0628\u064e\u0627\u062f\u0650","j":3,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0653\u0644\u0650 \u0639\u0650\u0645\u06e1\u0631\u064e\u0627\u0646\u064e"},{"s":3,"n":31,"t":"\u0642\u064f\u0644\u0652 \u0625\u0650\u0646 \u0643\u064f\u0646\u062a\u064f\u0645\u0652 \u062a\u064f\u062d\u0650\u0628\u0651\u064f\u0648\u0646\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u0641\u064e\u0671\u062a\u0651\u064e\u0628\u0650\u0639\u064f\u0648\u0646\u0650\u0649 \u064a\u064f\u062d\u0652\u0628\u0650\u0628\u0652\u0643\u064f\u0645\u064f \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0648\u064e\u064a\u064e\u063a\u0652\u0641\u0650\u0631\u0652 \u0644\u064e\u0643\u064f\u0645\u0652 \u0630\u064f\u0646\u064f\u0648\u0628\u064e\u0643\u064f\u0645\u0652 \u06d7 \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\