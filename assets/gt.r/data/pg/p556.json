[{"s":64,"n":1,"t":"\u0628\u0650\u0633\u0652\u0645\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0652\u0645\u064e\u0670\u0646\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u0650 \u064a\u064f\u0633\u064e\u0628\u0651\u0650\u062d\u064f \u0644\u0650\u0644\u0651\u064e\u0647\u0650 \u0645\u064e\u0627 \u0641\u0650\u0649 \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0645\u064e\u0627 \u0641\u0650\u0649 \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u06d6 \u0644\u064e\u0647\u064f \u0671\u0644\u0652\u0645\u064f\u0644\u0652\u0643\u064f \u0648\u064e\u0644\u064e\u0647\u064f \u0671\u0644\u0652\u062d\u064e\u0645\u0652\u062f\u064f \u06d6 \u0648\u064e\u0647\u064f\u0648\u064e \u0639\u064e\u0644\u064e\u0649\u0670 \u0643\u064f\u0644\u0651\u0650 \u0634\u064e\u0649\u0652\u0621\u064d\u06e2 \u0642\u064e\u062f\u0650\u064a\u0631\u064c","j":28,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u062a\u0651\u064e\u063a\u064e\u0627\u0628\u064f\u0646\u0650"},{"s":64,"n":2,"t":"\u0647\u064f\u0648\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u0649 \u062e\u064e\u0644\u064e\u0642\u064e\u0643\u064f\u0645\u0652 \u0641\u064e\u0645\u0650\u0646\u0643\u064f\u0645\u0652 \u0643\u064e\u0627\u0641\u0650\u0631\u064c\u06ed \u0648\u064e\u0645\u0650\u0646\u0643\u064f\u0645 \u0645\u0651\u064f\u0624\u0652\u0645\u0650\u0646\u064c\u06ed \u06da \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0628\u0650\u0645\u064e\u0627 \u062a\u064e\u0639\u0652\u0645\u064e\u0644\u064f\u0648\u0646\u064e \u0628\u064e\u0635\u0650\u064a\u0631\u064c","j":28},{"s":64,"n":3,"t":"\u062e\u064e\u0644\u064e\u0642\u064e \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u064e \u0628\u0650\u0671\u0644\u0652\u062d\u064e\u0642\u0651\u0650 \u0648\u064e\u0635\u064e\u0648\u0651\u064e\u0631\u064e\u0643\u064f\u0645\u0652 \u0641\u064e\u0623\u064e\u062d\u0652\u0633\u064e\u0646\u064e \u0635\u064f\u0648\u064e\u0631\u064e\u0643\u064f\u0645\u0652 \u06d6 \u0648\u064e\u0625\u0650\u0644\u064e\u064a\u0652\u0647\u0650 \u0671\u0644\u0652\u0645\u064e\u0635\u0650\u064a\u0631\u064f","j":28},{"s":64,"n":4,"t":"\u064a\u064e\u0639\u0652\u0644\u064e\u0645\u064f \u0645\u064e\u0627 \u0641\u0650\u0649 \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u0648\u064e\u064a\u064e\u0639\u0652\u0644\u064e\u0645\u064f \u0645\u064e\u0627 \u062a\u064f\u0633\u0650\u0631\u0651\u064f\u0648\u0646\u064e \u0648\u064e\u0645\u064e\u0627 \u062a\u064f\u0639\u0652\u0644\u0650\u0646\u064f\u0648\u0646\u064e \u06da \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0639\u064e\u0644\u0650\u064a\u0645\u064c\u06e2 \u0628\u0650\u0630\u064e\u0627\u062a\u0650 \u0671\u0644\u0635\u0651\u064f\u062f\u064f\u0648\u0631\u0650","j":28},{"s":64,"n":5,"t":"\u0623\u064e\u0644\u064e\u0645\u0652 \u064a\u064e\u0623\u0652\u062a\u0650\u0643\u064f\u0645\u0652 \u0646\u064e\u0628\u064e\u0624\u064f\u0627\u06df \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0643\u064e\u0641\u064e\u0631\u064f\u0648\u0627\u06df \u0645\u0650\u0646 \u0642\u064e\u0628\u0652\u0644\u064f \u0641\u064e\u0630\u064e\u0627\u0642\u064f\u0648\u0627\u06df \u0648\u064e\u0628\u064e\u0627\u0644\u064e \u0623\u064e\u0645\u0652\u0631\u0650\u0647\u0650\u0645\u0652 \u0648\u064e\u0644\u064e\u0647\u064f\u0645\u0652 \u0639\u064e\u0630\u064e\u0627\u0628\u064c \u0623\u064e\u0644\u0650\u064a\u0645\u064c\u06ed","j":28},{"s":64,"n":6,"t":"\u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0628\u0650\u0623\u064e\u0646\u0651\u064e\u0647\u064f\u06e5 \u0643\u064e\u0627\u0646\u064e\u062a \u062a\u0651\u064e\u0623\u0652\u062a\u0650\u064a\u0647\u0650\u0645\u0652 \u0631\u064f\u0633\u064f\u0644\u064f\u0647\u064f\u0645 \u0628\u0650\u0671\u0644\u0652\u0628\u064e\u064a\u0651\u0650\u0646\u064e\u0670\u062a\u0650 \u0641\u064e\u0642\u064e\u0627\u0644\u064f\u0648\u0653\u0627\u06df \u0623\u064e\u0628\u064e\u0634\u064e\u0631\u064c\u06ed \u064a\u064e\u0647\u0652\u062f\u064f\u0648\u0646\u064e\u0646\u064e\u0627 \u0641\u064e\u0643\u064e\u0641\u064e\u0631\u064f\u0648\u0627\u06df \u0648\u064e\u062a\u064e\u0648\u064e\u0644\u0651\u064e\u0648\u0627\u06df \u06da \u0648\u0651\u064e\u0671\u0633\u0652\u062a\u064e\u063a\u0652\u0646\u064e\u0649 \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u06da \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u063a\u064e\u0646\u0650\u0649\u0651\u064c \u062d\u064e\u0645\u0650\u064a\u062f\u064c\u06ed","j":28},{"s":64,"n":7,"t":"\u0632\u064e\u0639\u064e\u0645\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0643\u064e\u0641\u064e\u0631\u064f\u0648\u0653\u0627\u06df \u0623\u064e\u0646 \u0644\u0651\u064e\u0646 \u064a\u064f\u0628\u0652\u0639\u064e\u062b\u064f\u0648\u0627\u06df \u06da \u0642\u064f\u0644\u0652 \u0628\u064e\u0644\u064e\u0649\u0670 \u0648\u064e\u0631\u064e\u0628\u0651\u0650\u0649 \u0644\u064e\u062a\u064f\u0628\u0652\u0639\u064e\u062b\u064f\u0646\u0651\u064e \u062b\u064f\u0645\u0651\u064e \u0644\u064e\u062a\u064f\u0646\u064e\u0628\u0651\u064e\u0624\u064f\u0646\u0651\u064e \u0628\u0650\u0645\u064e\u0627 \u0639\u064e\u0645\u0650\u0644\u0652\u062a\u064f\u0645\u0652 \u06da \u0648\u064e\u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0639\u064e\u0644\u064e\u0649 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u064a\u064e\u0633\u0650\u064a\u0631\u064c\u06ed","j":28},{"s":64,"n":8,"t":"\u0641\u064e\u0640\u0654\u064e\u0627\u0645\u0650\u0646\u064f\u0648\u0627\u06df \u0628\u0650\u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0648\u064e\u0631\u064e\u0633\u064f\u0648\u0644\u0650\u0647\u0650\u06e6 \u0648\u064e\u0671\u0644\u0646\u0651\u064f\u0648\u0631\u0650 \u0671\u0644\u0651\u064e\u0630\u0650\u0649\u0653 \u0623\u064e\u0646\u0632\u064e\u0644\u0652\u0646\u064e\u0627 \u06da \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0628\u0650\u0645\u064e\u0627 \u062a\u064e\u0639\u0