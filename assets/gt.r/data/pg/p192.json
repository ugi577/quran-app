[{"s":9,"n":32,"t":"\u064a\u064f\u0631\u0650\u064a\u062f\u064f\u0648\u0646\u064e \u0623\u064e\u0646 \u064a\u064f\u0637\u0652\u0641\u0650\u0640\u0654\u064f\u0648\u0627\u06df \u0646\u064f\u0648\u0631\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0628\u0650\u0623\u064e\u0641\u0652\u0648\u064e\u0670\u0647\u0650\u0647\u0650\u0645\u0652 \u0648\u064e\u064a\u064e\u0623\u0652\u0628\u064e\u0649 \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0625\u0650\u0644\u0651\u064e\u0627\u0653 \u0623\u064e\u0646 \u064a\u064f\u062a\u0650\u0645\u0651\u064e \u0646\u064f\u0648\u0631\u064e\u0647\u064f\u06e5 \u0648\u064e\u0644\u064e\u0648\u0652 \u0643\u064e\u0631\u0650\u0647\u064e \u0671\u0644\u0652\u0643\u064e\u0670\u0641\u0650\u0631\u064f\u0648\u0646\u064e","j":10,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u062a\u0651\u064e\u0648\u06e1\u0628\u064e\u0629\u0650"},{"s":9,"n":33,"t":"\u0647\u064f\u0648\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u0649\u0653 \u0623\u064e\u0631\u0652\u0633\u064e\u0644\u064e \u0631\u064e\u0633\u064f\u0648\u0644\u064e\u0647\u064f\u06e5 \u0628\u0650\u0671\u0644\u0652\u0647\u064f\u062f\u064e\u0649\u0670 \u0648\u064e\u062f\u0650\u064a\u0646\u0650 \u0671\u0644\u0652\u062d\u064e\u0642\u0651\u0650 \u0644\u0650\u064a\u064f\u0638\u0652\u0647\u0650\u0631\u064e\u0647\u064f\u06e5 \u0639\u064e\u0644\u064e\u0649 \u0671\u0644\u062f\u0651\u0650\u064a\u0646\u0650 \u0643\u064f\u0644\u0651\u0650\u0647\u0650\u06e6 \u0648\u064e\u0644\u064e\u0648\u0652 \u0643\u064e\u0631\u0650\u0647\u064e \u0671\u0644\u0652\u0645\u064f\u0634\u0652\u0631\u0650\u0643\u064f\u0648\u0646\u064e","j":10},{"s":9,"n":34,"t":"\u06de \u064a\u064e\u0670\u0653\u0623\u064e\u064a\u0651\u064f\u0647\u064e\u0627 \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0621\u064e\u0627\u0645\u064e\u0646\u064f\u0648\u0653\u0627\u06df \u0625\u0650\u0646\u0651\u064e \u0643\u064e\u062b\u0650\u064a\u0631\u064b\u06ed\u0627 \u0645\u0651\u0650\u0646\u064e \u0671\u0644\u0652\u0623\u064e\u062d\u0652\u0628\u064e\