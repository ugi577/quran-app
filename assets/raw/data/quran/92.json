{"n":92,"na":"الّيل","nl":"Al-Lail","tt":"Mekah","ja":21,"ay":[{"n":1,"a":"وَالَّيْلِ اِذَا يَغْشٰىۙ"},{"n":2,"a":"وَالنَّهَارِ اِذَا تَجَلّٰىۙ"},{"n":3,"a":"وَمَا خَلَقَ الذَّكَرَ وَالْاُنْثٰىٓ ۙ"},{"n":4,"a":"اِنَّ سَعْيَكُمْ لَشَتّٰىۗ"},{"n":5,"a":"فَاَمَّا مَنْ اَعْطٰى وَاتَّقٰىۙ"},{"n":6,"a":"وَصَدَّقَ بِالْحُسْنٰىۙ"},{"n":7,"a":"فَسَنُيَسِّرُهٗ لِلْيُسْرٰىۗ"},{"n":8,"a":"وَاَمَّا مَنْۢ بَخِلَ وَاسْتَغْنٰىۙ"},{"n":9,"a":"وَكَذَّبَ بِالْحُسْنٰىۙ"},{"n":10,"a":"فَسَنُيَسِّرُهٗ لِلْعُسْرٰىۗ"},{"n":11,"a":"وَمَا يُغْنِيْ عَنْهُ مَالُهٗٓ اِذَا تَرَدّٰىٓۙ"},{"n":12,"a":"اِنَّ عَلَيْنَا لَلْهُدٰىۖ"},{"n":13,"a":"وَاِنَّ لَنَا لَلْاٰخِرَةَ وَالْاُوْلٰىۗ"},{"n":14,"a":"فَاَنْذَرْتُكُمْ نَارًا تَلَظّٰىۚ"},{"n":15,"a":"لَا يَصْلٰىهَآ اِلَّا الْاَشْقَىۙ"},{"n":16,"a":"الَّذِيْ كَذَّبَ وَتَوَلّٰىۗ"},{"n":17,"a":"وَسَيُجَنَّبُهَا الْاَتْقَىۙ"},{"n":18,"a":"الَّذِيْ يُؤْتِيْ مَالَهٗ يَتَزَكّٰىۚ"},{"n":19,"a":"وَمَا لِاَحَدٍ عِنْدَهٗ مِنْ نِّعْمَةٍ تُجْزٰىٓۙ"},{"n":20,"a":"اِلَّا ابْتِغَاۤءَ وَجْهِ رَبِّهِ الْاَعْلٰىۚ"},{"n":21,"a":"وَلَسَوْفَ يَرْضٰى ࣖ"}]}