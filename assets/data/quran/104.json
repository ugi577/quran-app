{"nomor":104,"nama":"الهمزة","namaLatin":"Al-Humazah","tempatTurun":"Mekah","jumlahAyat":9,"ayat":[{"nomor":1,"arab":"وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍۙ","terjemah":"Celakalah bagi setiap pengumpat dan pencela,"},{"nomor":2,"arab":" ۨالَّذِيْ جَمَعَ مَالًا وَّعَدَّدَهٗۙ","terjemah":"yang mengumpulkan harta dan menghitung-hitungnya,"},{"nomor":3,"arab":"يَحْسَبُ اَنَّ مَالَهٗٓ اَخْلَدَهٗۚ","terjemah":"dia (manusia) mengira bahwa hartanya itu dapat mengekalkannya."},{"nomor":4,"arab":"كَلَّا لَيُنْۢبَذَنَّ فِى الْحُطَمَةِۖ","terjemah":"Sekali-kali tidak! Pasti dia akan dilemparkan ke dalam (neraka) Hutamah."},{"nomor":5,"arab":"وَمَآ اَدْرٰىكَ مَا الْحُطَمَةُ ۗ","terjemah":"Dan tahukah kamu apakah (neraka) Hutamah itu?"},{"nomor":6,"arab":"نَارُ اللّٰهِ الْمُوْقَدَةُۙ","terjemah":"(Yaitu) api  (azab) Allah yang dinyalakan,"},{"nomor":7,"arab":"الَّتِيْ تَطَّلِعُ عَلَى الْاَفْـِٕدَةِۗ","terjemah":"yang (membakar) sampai ke hati."},{"nomor":8,"arab":"اِنَّهَا عَلَيْهِمْ مُّؤْصَدَةٌۙ","terjemah":"Sungguh, api itu ditutup rapat atas (diri) mereka,"},{"nomor":9,"arab":"فِيْ عَمَدٍ مُّمَدَّدَةٍ ࣖ","terjemah":"(sedang mereka itu) diikat pada tiang-tiang yang panjang."}]}