{"n":107,"na":"الماعون","nl":"Al-Ma'un","tt":"Mekah","ja":7,"ay":[{"n":1,"a":"اَرَءَيْتَ الَّذِيْ يُكَذِّبُ بِالدِّيْنِۗ"},{"n":2,"a":"فَذٰلِكَ الَّذِيْ يَدُعُّ الْيَتِيْمَۙ"},{"n":3,"a":"وَلَا يَحُضُّ عَلٰى طَعَامِ الْمِسْكِيْنِۗ"},{"n":4,"a":"فَوَيْلٌ لِّلْمُصَلِّيْنَۙ"},{"n":5,"a":"الَّذِيْنَ هُمْ عَنْ صَلَاتِهِمْ سَاهُوْنَۙ"},{"n":6,"a":"الَّذِيْنَ هُمْ يُرَاۤءُوْنَۙ"},{"n":7,"a":"وَيَمْنَعُوْنَ الْمَاعُوْنَ ࣖ"}]}