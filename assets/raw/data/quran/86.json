{"n":86,"na":"الطارق","nl":"At-Tariq","tt":"Mekah","ja":17,"ay":[{"n":1,"a":"وَالسَّمَاۤءِ وَالطَّارِقِۙ "},{"n":2,"a":"وَمَآ اَدْرٰىكَ مَا الطَّارِقُۙ "},{"n":3,"a":"النَّجْمُ الثَّاقِبُۙ "},{"n":4,"a":"اِنْ كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌۗ "},{"n":5,"a":"فَلْيَنْظُرِ الْاِنْسَانُ مِمَّ خُلِقَ "},{"n":6,"a":"خُلِقَ مِنْ مَّاۤءٍ دَافِقٍۙ "},{"n":7,"a":"يَّخْرُجُ مِنْۢ بَيْنِ الصُّلْبِ وَالتَّرَاۤىِٕبِۗ "},{"n":8,"a":"اِنَّهٗ عَلٰى رَجْعِهٖ لَقَادِرٌۗ "},{"n":9,"a":"يَوْمَ تُبْلَى السَّرَاۤىِٕرُۙ "},{"n":10,"a":"فَمَا لَهٗ مِنْ قُوَّةٍ وَّلَا نَاصِرٍۗ "},{"n":11,"a":"وَالسَّمَاۤءِ ذَاتِ الرَّجْعِۙ "},{"n":12,"a":"وَالْاَرْضِ ذَاتِ الصَّدْعِۙ "},{"n":13,"a":"اِنَّهٗ لَقَوْلٌ فَصْلٌۙ "},{"n":14,"a":"وَّمَا هُوَ بِالْهَزْلِۗ "},{"n":15,"a":"اِنَّهُمْ يَكِيْدُوْنَ كَيْدًاۙ "},{"n":16,"a":"وَّاَكِيْدُ كَيْدًاۖ "},{"n":17,"a":"فَمَهِّلِ الْكٰفِرِيْنَ اَمْهِلْهُمْ رُوَيْدًا ࣖ "}]}