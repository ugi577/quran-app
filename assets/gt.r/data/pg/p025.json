[{"s":2,"n":164,"t":"\u0625\u0650\u0646\u0651\u064e \u0641\u0650\u0649 \u062e\u064e\u0644\u0652\u0642\u0650 \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u0648\u064e\u0671\u062e\u0652\u062a\u0650\u0644\u064e\u0670\u0641\u0650 \u0671\u0644\u0651\u064e\u064a\u0652\u0644\u0650 \u0648\u064e\u0671\u0644\u0646\u0651\u064e\u0647\u064e\u0627\u0631\u0650 \u0648\u064e\u0671\u0644\u0652\u0641\u064f\u0644\u0652\u0643\u0650 \u0671\u0644\u0651\u064e\u062a\u0650\u0649 \u062a\u064e\u062c\u0652\u0631\u0650\u0649 \u0641\u0650\u0649 \u0671\u0644\u0652\u0628\u064e\u062d\u0652\u0631\u0650 \u0628\u0650\u0645\u064e\u0627 \u064a\u064e\u0646\u0641\u064e\u0639\u064f \u0671\u0644\u0646\u0651\u064e\u0627\u0633\u064e \u0648\u064e\u0645\u064e\u0627\u0653 \u0623\u064e\u0646\u0632\u064e\u0644\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0645\u0650\u0646\u064e \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0627\u0653\u0621\u0650 \u0645\u0650\u0646 \u0645\u0651\u064e\u0627\u0653\u0621\u064d\u06e2 \u0641\u064e\u0623\u064e\u062d\u0652\u064a\u064e\u0627 \u0628\u0650\u0647\u0650 \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u064e \u0628\u064e\u0639\u0652\u062f\u064e \u0645\u064e\u0648\u0652\u062a\u0650\u0647\u064e\u0627 \u0648\u064e\u0628\u064e\u062b\u0651\u064e \u0641\u0650\u064a\u0647\u064e\u0627 \u0645\u0650\u0646 \u0643\u064f\u0644\u0651\u0650 \u062f\u064e\u0627\u0653\u0628\u0651\u064e\u0629\u064d\u06e2 \u0648\u064e\u062a\u064e\u0635\u0652\u0631\u0650\u064a\u0641\u0650 \u0671\u0644\u0631\u0651\u0650\u064a\u064e\u0670\u062d\u0650 \u0648\u064e\u0671\u0644\u0633\u0651\u064e\u062d\u064e\u0627\u0628\u0650 \u0671\u0644\u0652\u0645\u064f\u0633\u064e\u062e\u0651\u064e\u0631\u0650 \u0628\u064e\u064a\u0652\u0646\u064e \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0627\u0653\u0621\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u0644\u064e\u0621\u064e\u0627\u064a\u064e\u0670\u062a\