{"n":1,"na":"الفاتحة","nl":"Al-Fatihah","tt":"Mekah","ja":7,"ay":[{"n":1,"a":"بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ"},{"n":2,"a":"اَلْحَمْدُ لِلّٰهِ رَبِّ الْعٰلَمِيْنَۙ"},{"n":3,"a":"الرَّحْمٰنِ الرَّحِيْمِۙ"},{"n":4,"a":"مٰلِكِ يَوْمِ الدِّيْنِۗ"},{"n":5,"a":"اِيَّاكَ نَعْبُدُ وَاِيَّاكَ نَسْتَعِيْنُۗ"},{"n":6,"a":"اِهْدِنَا الصِّرَاطَ الْمُسْتَقِيْمَ ۙ"},{"n":7,"a":"صِرَاطَ الَّذِيْنَ اَنْعَمْتَ عَلَيْهِمْ ەۙ غَيْرِ الْمَغْضُوْبِ عَلَيْهِمْ وَلَا الضَّاۤلِّيْنَ ࣖ"}]}