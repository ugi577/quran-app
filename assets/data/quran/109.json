{"nomor":109,"nama":"الكٰفرون","namaLatin":"Al-Kafirun","tempatTurun":"Mekah","jumlahAyat":6,"ayat":[{"nomor":1,"arab":"قُلْ يٰٓاَيُّهَا الْكٰفِرُوْنَۙ","terjemah":"Katakanlah (Muhammad), “Wahai orang-orang kafir!"},{"nomor":2,"arab":"لَآ اَعْبُدُ مَا تَعْبُدُوْنَۙ","terjemah":"aku tidak akan menyembah apa yang kamu sembah,"},{"nomor":3,"arab":"وَلَآ اَنْتُمْ عٰبِدُوْنَ مَآ اَعْبُدُۚ","terjemah":"dan kamu bukan penyembah apa yang aku sembah,"},{"nomor":4,"arab":"وَلَآ اَنَا۠ عَابِدٌ مَّا عَبَدْتُّمْۙ","terjemah":"dan aku tidak pernah menjadi penyembah apa yang kamu sembah,"},{"nomor":5,"arab":"وَلَآ اَنْتُمْ عٰبِدُوْنَ مَآ اَعْبُدُۗ","terjemah":"dan kamu tidak pernah (pula) menjadi penyembah apa yang aku sembah."},{"nomor":6,"arab":"لَكُمْ دِيْنُكُمْ وَلِيَ دِيْنِ ࣖ","terjemah":"Untukmu agamamu, dan untukku agamaku.”"}]}