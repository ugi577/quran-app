{"n":95,"na":"التين","nl":"At-Tin","tt":"Mekah","ja":8,"ay":[{"n":1,"a":"وَالتِّيْنِ وَالزَّيْتُوْنِۙ"},{"n":2,"a":"وَطُوْرِ سِيْنِيْنَۙ"},{"n":3,"a":"وَهٰذَا الْبَلَدِ الْاَمِيْنِۙ"},{"n":4,"a":"لَقَدْ خَلَقْنَا الْاِنْسَانَ فِيْٓ اَحْسَنِ تَقْوِيْمٍۖ"},{"n":5,"a":"ثُمَّ رَدَدْنٰهُ اَسْفَلَ سَافِلِيْنَۙ"},{"n":6,"a":"اِلَّا الَّذِيْنَ اٰمَنُوْا وَعَمِلُوا الصّٰلِحٰتِ فَلَهُمْ اَجْرٌ غَيْرُ مَمْنُوْنٍۗ"},{"n":7,"a":"فَمَا يُكَذِّبُكَ بَعْدُ بِالدِّيْنِۗ"},{"n":8,"a":"اَلَيْسَ اللّٰهُ بِاَحْكَمِ الْحٰكِمِيْنَ ࣖ"}]}