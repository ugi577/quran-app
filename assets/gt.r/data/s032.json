{"n":32,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0633\u0651\u064e\u062c\u06e1\u062f\u064e\u0629\u0650","en":"As-Sajda","ayat":[{"n":1,"t":"\u0628\u0650\u0633\u0652\u0645\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0652\u0645\u064e\u0670\u0646\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u0650 \u0627\u0644\u0653\u0645\u0653","p":415,"j":21},{"n":2,"t":"\u062a\u064e\u0646\u0632\u0650\u064a\u0644\u064f \u0671\u0644\u0652\u0643\u0650\u062a\u064e\u0670\u0628\u0650 \u0644\u064e\u0627 \u0631\u064e\u064a\u0652\u0628\u064e \u0641\u0650\u064a\u0647\u0650 \u0645\u0650\u0646 \u0631\u0651\u064e\u0628\u0651\u0650 \u0671\u0644\u0652\u0639\u064e\u0670\u0644\u064e\u0645\u0650\u064a\u0646\u064e","p":415,"j":21},{"n":3,"t":"\u0623\u064e\u0645\u0652 \u064a\u064e\u0642\u064f\u0648\u0644\u064f\u0648\u0646\u064e \u0671\u0641\u0652\u062a\u064e\u0631\u064e\u0649\u0670\u0647\u064f \u06da \u0628\u064e\u0644\u0652 \u0647\u064f\u0648\u064e \u0671\u0644\u0652\u062d\u064e\u0642\u0651\u064f \u0645\u0650\u0646 \u0631\u0651\u064e\u0628\u0651\u0650\u0643\u064e \u0644\u0650\u062a\u064f\u0646\u0630\u0650\u0631\u064e \u0642\u064e\u0648\u0652\u0645\u064b\u06ed\u0627 \u0645\u0651\u064e\u0627\u0653 \u0623\u064e\u062a\u064e\u0649\u0670\u0647\u064f\u0645 \u0645\u0651\u0650\u0646 \u0646\u0651\u064e\u0630\u0650\u064a\u0631\u064d\u06e2 \u0645\u0651\u0650\u0646 \u0642\u064e\u0628\u0652\u0644\u0650\u0643\u064e \u0644\u064e\u0639\u064e\u0644\u0651\u064e\u0647\u064f\u0645\u0652 \u064a\u064e\u0647\u0652\u062a\u064e\u062f\u064f\u0648\u0646\u064e","p":415,"j":21},{"n":4,"t":"\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0671\u0644\u0651\u064e\u0630\u0650\u0649 \u062e\u064e\u0644\u064e\u0642\u064e \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u064e \u0648\u064e\u0645\u064e\u0627 \u0628\u064e\u064a\u0652\u0646\u064e\u0647\u064f\u0645\u064e\u0627 \u0641\u0650\u0649 \u0633\u0650\u062a\u0651\u064e\u0629\u0650 \u0623\u064e\u064a\u0651\u064e\u0627\u0645\u064d\u06e2 \u062b\u064f\u0645\u0651\u064e \u0671\u0633\u0652\u062a\u064e\u0648\u064e\u0649\u0670 \u0639\u064e\u0644\u064e\u0649 \u0671\u0644\u0652\u0639\u064e\u0631\u0652\u0634\u0650 \u06d6 \u0645\u064e\u0627 \u0644\u064e\u0643\u064f\u0645 \u0645\u0651\u0650\u0646 \u062f\u064f\u0648\u0646\u0650\u0647\u0650\u06e6 \u0645\u0650\u0646 \u0648\u064e\u0644\u0650\u0649\u0651\u064d\u06e2 \u0648\u064e\u0644\u064e\u0627 \u0634\u064e\u0641\u0650\u064a\u0639\u064d \u06da \u0623\u064e\u0641\u064e\u0644\u064e\u0627 \u062a\u064e\u062a\u064e\u0630\u064e\u0643\u0651\u064e\u0631\u064f\u0648\u0646\u064e","p":415,"j":21},{"n":5,"t":"\u064a\u064f\u062f\u064e\u0628\u0651\u0650\u0631\u064f \u0671\u0644\u0652\u0623\u064e\u0645\u0652\u0631\u064e \u0645\u0650\u0646\u064e \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0627\u0653\u0621\u0650 \u0625\u0650\u0644\u064e\u0649 \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u062b\u064f\u0645\u0651\u064e \u064a\u064e\u0639\u0652\u0631\u064f\u062c\u064f \u0625\u0650\u0644\u064e\u064a\u0652\u0647\u0650 \u0641\u0650\u0649 \u064a\u064e\u0648\u0652\u0645\u064d\u06e2 \u0643\u064e\u0627\u0646\u064e \u0645\u0650\u0642\u0652\u062f\u064e\u0627\u0631\u064f\u0647\u064f\u06e5\u0653 \u0623\u064e\u0644\u0652\u0641\u064e \u0633\u064e\u0646\u064e\u0629\u064d\u06e2 \u0645\u0651\u0650\u0645\u0651\u064e\u0627 \u062a\u064e\u0639\u064f\u062f\u0651\u064f\u0648\u0646\u064e","p":415,"j":21},{"n":6,"t":"\u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0639\u064e\u0670\u0644\u0650\u0645\u064f \u0671\u0644\u0652\u063a\u064e\u064a\u0652\u0628\u0650 \u0648\u064e\u0671\u0644\u0634\u0651\u064e\u0647\u064e\u0670\u062f\u064e\u0629\u0650 \u0671\u0644\u0652\u0639\u064e\u0632\u0650\u064a\u0632\u064f \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u064f","p":415,"j":21},{"n":7,"t":"\u0671\u0644\u0651\u064e\u0630\u0650\u0649\u0653 \u0623\u064e\u062d\u0652\u0633\u064e\u0646\u064e \u0643\u064f\u0644\u0651\u064e \u0634\u064e\u0649\u0652\u0621\u064d \u062e\u064e\u0644\u064e\u0642\u064e\u0647\u064f\u06e5 \u06d6 \u0648\u064e\u0628\u064e\u062f\u064e\u0623\u064e \u062e\u064e\u0644\u0652\u0642\u064e \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u0650 \u0645\u0650\u0646 \u0637\u0650\u064a\u0646\u064d\u06e2","p":415,"j":21},{"n":8,"t":"\u062b\u064f\u0645\u0651\u064e \u062c\u064e\u0639\u064e\u0644\u064e \u0646\u064e\u0633\u0652\u0644\u064e\u0647\u064f\u06e5 \u0645\u0650\u0646 \u0633\u064f\u0644\u064e\u0670\u0644\u064e\u0629\u064d\u06e2 \u0645\u0651\u0650\u0646 \u0645\u0651\u064e\u0627\u0653\u0621\u064d\u06e2 \u0645\u0651\u064e\u0647\u0650\u064a\u0646\u064d\u06e2","p":415,"j":21},{"n":9,"t":"\u062b\u064f\u0645\u0651\u064e \u0633\u064e\u0648\u0651\u064e\u0649\u0670\u0647\u064f \u0648\u064e\u0646\u064e\u0641\u064e\u062e\u064e \u0641\u0650\u064a\u0647\u0650 \u0645\u0650\u0646 \u0631\u0651\u064f\u0648\u062d\u0650\u0647\u0650\u06e6 \u06d6 \u0648\u064e\u062c\u064e\u0639\u064e\u0644\u064e \u0644\u064e\u0643\u064f\u0645\u064f \u0671\u0644\u0633\u0651\u064e\u0645\u0652\u0639\u064e \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0628\u0652\u0635\u064e\u0670\u0631\u064e \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0641\u0652\u0640\u0654\u0650\u062f\u064e\u0629\u064e \u06da \u0642\u064e\u0644\u0650\u064a\u0644\u064b\u06ed\u0627 \u0645\u0651\u064e\u0627 \u062a\u064e\u0634\u0652\u0643\u064f\u0631\u064f\u0648\u0646\u064e","p":415,"j":21},{"n":10,"t":"\u0648\u064e\u0642\u064e\u0627\u0644\u064f\u0648\u0653\u0627\u06df \u0623\u064e\u0621\u0650\u0630\u064e\u0627 \u0636\u064e\u0644\u064e\u0644\u0652\u0646\u064e\u0627 \u0641\u0650\u0649 \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u0623\u064e\u0621\u0650\u0646\u0651\u064e\u0627 \u0644\u064e\u0641\u0650\u0649 \u062e\u064e\u0644\u0652\u0642\u064d\u06e2 \u062c\u064e\u062f\u0650\u064a\u062f\u064d\u06ed \u06da \u0628\u064e\u0644\u0652 \u0647\u064f\u0645 \u0628\u0650\u0644\u0650\u0642\u064e\u0627\u0653\u0621\