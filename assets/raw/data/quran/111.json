{"n":111,"na":"اللهب","nl":"Al-Lahab","tt":"Mekah","ja":5,"ay":[{"n":1,"a":"تَبَّتْ يَدَآ اَبِيْ لَهَبٍ وَّتَبَّۗ"},{"n":2,"a":"مَآ اَغْنٰى عَنْهُ مَالُهٗ وَمَا كَسَبَۗ"},{"n":3,"a":"سَيَصْلٰى نَارًا ذَاتَ لَهَبٍۙ"},{"n":4,"a":"وَّامْرَاَتُهٗ ۗحَمَّالَةَ الْحَطَبِۚ"},{"n":5,"a":"فِيْ جِيْدِهَا حَبْلٌ مِّنْ مَّسَدٍ ࣖ"}]}