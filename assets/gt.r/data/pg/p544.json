[{"s":58,"n":12,"t":"\u064a\u064e\u0670\u0653\u0623\u064e\u064a\u0651\u064f\u0647\u064e\u0627 \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0621\u064e\u0627\u0645\u064e\u0646\u064f\u0648\u0653\u0627\u06df \u0625\u0650\u0630\u064e\u0627 \u0646\u064e\u0670\u062c\u064e\u064a\u0652\u062a\u064f\u0645\u064f \u0671\u0644\u0631\u0651\u064e\u0633\u064f\u0648\u0644\u064e \u0641\u064e\u0642\u064e\u062f\u0651\u0650\u0645\u064f\u0648\u0627\u06df \u0628\u064e\u064a\u0652\u0646\u064e \u064a\u064e\u062f\u064e\u0649\u0652 \u0646\u064e\u062c\u0652\u0648\u064e\u0649\u0670\u0643\u064f\u0645\u0652 \u0635\u064e\u062f\u064e\u0642\u064e\u0629\u064b\u06ed \u06da \u0630\u064e\u0670\u0644\u0650\u0643\u064e \u062e\u064e\u064a\u0652\u0631\u064c\u06ed \u0644\u0651\u064e\u0643\u064f\u0645\u0652 \u0648\u064e\u0623\u064e\u0637\u0652\u0647\u064e\u0631\u064f \u06da \u0641\u064e\u0625\u0650\u0646 \u0644\u0651\u064e\u0645\u0652 \u062a\u064e\u062c\u0650\u062f\u064f\u0648\u0627\u06df \u0641\u064e\u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u063a\u064e\u0641\u064f\u0648\u0631\u064c\u06ed \u0631\u0651\u064e\u062d\u0650\u064a\u0645\u064c","j":28,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0645\u064f\u062c\u064e\u0627\u062f\u0644\u064e\u0629\u0650"},{"s":58,"n":13,"t":"\u0621\u064e\u0623\u064e\u0634\u0652\u0641\u064e\u0642\u0652\u062a\u064f\u0645\u0652 \u0623\u064e\u0646 \u062a\u064f\u0642\u064e\u062f\u0651\u0650\u0645\u064f\u0648\u0627\u06df \u0628\u064e\u064a\u0652\u0646\u064e \u064a\u064e\u062f\u064e\u0649\u0652 \u0646\u064e\u062c\u0652\u0648\u064e\u0649\u0670\u0643\u064f\u0645\u0652 \u0635\u064e\u062f\u064e\u0642\u064e\u0670\u062a\u064d\u06e2 \u06da \u0641\u064e\u0625\u0650\u0630\u0652 \u0644\u064e\u0645\u0652 \u062a\u064e\u0641\u0652\u0639\u064e\u0644\u064f\u0648\u0627\u06df \u0648\u064e\u062a\u064e\u0627\u0628\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0639\u064e\u0644\u064e\u064a\u0652\u0643\u064f\u0645\u0652 \u0641\u064e\u0623\u064e\