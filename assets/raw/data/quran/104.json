{"n":104,"na":"الهمزة","nl":"Al-Humazah","tt":"Mekah","ja":9,"ay":[{"n":1,"a":"وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍۙ"},{"n":2,"a":" ۨالَّذِيْ جَمَعَ مَالًا وَّعَدَّدَهٗۙ"},{"n":3,"a":"يَحْسَبُ اَنَّ مَالَهٗٓ اَخْلَدَهٗۚ"},{"n":4,"a":"كَلَّا لَيُنْۢبَذَنَّ فِى الْحُطَمَةِۖ"},{"n":5,"a":"وَمَآ اَدْرٰىكَ مَا الْحُطَمَةُ ۗ"},{"n":6,"a":"نَارُ اللّٰهِ الْمُوْقَدَةُۙ"},{"n":7,"a":"الَّتِيْ تَطَّلِعُ عَلَى الْاَفْـِٕدَةِۗ"},{"n":8,"a":"اِنَّهَا عَلَيْهِمْ مُّؤْصَدَةٌۙ"},{"n":9,"a":"فِيْ عَمَدٍ مُّمَدَّدَةٍ ࣖ"}]}