[{"s":35,"n":12,"t":"\u0648\u064e\u0645\u064e\u0627 \u064a\u064e\u0633\u0652\u062a\u064e\u0648\u0650\u0649 \u0671\u0644\u0652\u0628\u064e\u062d\u0652\u0631\u064e\u0627\u0646\u0650 \u0647\u064e\u0670\u0630\u064e\u0627 \u0639\u064e\u0630\u0652\u0628\u064c\u06ed \u0641\u064f\u0631\u064e\u0627\u062a\u064c\u06ed \u0633\u064e\u0627\u0653\u0626\u0650\u063a\u064c\u06ed \u0634\u064e\u0631\u064e\u0627\u0628\u064f\u0647\u064f\u06e5 \u0648\u064e\u0647\u064e\u0670\u0630\u064e\u0627 \u0645\u0650\u0644\u0652\u062d\u064c \u0623\u064f\u062c\u064e\u0627\u062c\u064c\u06ed \u06d6 \u0648\u064e\u0645\u0650\u0646 \u0643\u064f\u0644\u0651\u064d\u06e2 \u062a\u064e\u0623\u0652\u0643\u064f\u0644\u064f\u0648\u0646\u064e \u0644\u064e\u062d\u0652\u0645\u064b\u06ed\u0627 \u0637\u064e\u0631\u0650\u064a\u0651\u064b\u06ed\u0627 \u0648\u064e\u062a\u064e\u0633\u0652\u062a\u064e\u062e\u0652\u0631\u0650\u062c\u064f\u0648\u0646\u064e \u062d\u0650\u0644\u0652\u064a\u064e\u0629\u064b\u06ed \u062a\u064e\u0644\u0652\u0628\u064e\u0633\u064f\u0648\u0646\u064e\u0647\u064e\u0627 \u06d6 \u0648\u064e\u062a\u064e\u0631\u064e\u0649 \u0671\u0644\u0652\u0641\u064f\u0644\u0652\u0643\u064e \u0641\u0650\u064a\u0647\u0650 \u0645\u064e\u0648\u064e\u0627\u062e\u0650\u0631\u064e \u0644\u0650\u062a\u064e\u0628\u0652\u062a\u064e\u063a\u064f\u0648\u0627\u06df \u0645\u0650\u0646 \u0641\u064e\u0636\u0652\u0644\u0650\u0647\u0650\u06e6 \u0648\u064e\u0644\u064e\u0639\u064e\u0644\u0651\u064e\u0643\u064f\u0645\u0652 \u062a\u064e\u0634\u0652\u0643\u064f\u0631\u064f\u0648\u0646\u064e","j":22,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0641\u064e\u0627\u0637\u0650\u0631\u064d"},{"s":35,"n":13,"t":"\u064a\u064f\u0648\u0644\u0650\u062c\u064f \u0671\u0644\u0651\u064e\u064a\u0652\u0644\u064e \u0641\u0650\u0649 \u0671\u0644\u0646\u0651\u064e\u0647\u064e\u0627\u0631\u0650 \u0648\u064e\u064a\u064f\u0648\u0644\u0650\u062c\u064f \u0671\u0644\u0646\u0651\u064e\u0647\u064e\u0627\u0631\u064e \u0641\u0650\u0649 \u0671\u0644\u0651\u064e\u064a\u