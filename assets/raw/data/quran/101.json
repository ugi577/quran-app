{"n":101,"na":"القارعة","nl":"Al-Qari'ah","tt":"Mekah","ja":11,"ay":[{"n":1,"a":"اَلْقَارِعَةُۙ"},{"n":2,"a":"مَا الْقَارِعَةُ ۚ"},{"n":3,"a":"وَمَآ اَدْرٰىكَ مَا الْقَارِعَةُ ۗ"},{"n":4,"a":"يَوْمَ يَكُوْنُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوْثِۙ"},{"n":5,"a":"وَتَكُوْنُ الْجِبَالُ كَالْعِهْنِ الْمَنْفُوْشِۗ"},{"n":6,"a":"فَاَمَّا مَنْ ثَقُلَتْ مَوَازِينُهٗۙ"},{"n":7,"a":"فَهُوَ فِيْ عِيْشَةٍ رَّاضِيَةٍۗ"},{"n":8,"a":"وَاَمَّا مَنْ خَفَّتْ مَوَازِيْنُهٗۙ"},{"n":9,"a":"فَاُمُّهُ هَاوِيَةٌ  ۗ"},{"n":10,"a":"وَمَآ اَدْرٰىكَ مَا هِيَهْۗ"},{"n":11,"a":"نَارٌ حَامِيَةٌ ࣖ"}]}