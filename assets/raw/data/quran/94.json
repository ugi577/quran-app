{"n":94,"na":"الشرح","nl":"Asy-Syarh","tt":"Mekah","ja":8,"ay":[{"n":1,"a":"اَلَمْ نَشْرَحْ لَكَ صَدْرَكَۙ"},{"n":2,"a":"وَوَضَعْنَا عَنْكَ وِزْرَكَۙ"},{"n":3,"a":"الَّذِيْٓ اَنْقَضَ ظَهْرَكَۙ"},{"n":4,"a":"وَرَفَعْنَا لَكَ ذِكْرَكَۗ"},{"n":5,"a":"فَاِنَّ مَعَ الْعُسْرِ يُسْرًاۙ"},{"n":6,"a":"اِنَّ مَعَ الْعُسْرِ يُسْرًاۗ"},{"n":7,"a":"فَاِذَا فَرَغْتَ فَانْصَبْۙ"},{"n":8,"a":"وَاِلٰى رَبِّكَ فَارْغَبْ ࣖ"}]}