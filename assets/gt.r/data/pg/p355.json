[{"s":24,"n":37,"t":"\u0631\u0650\u062c\u064e\u0627\u0644\u064c\u06ed \u0644\u0651\u064e\u0627 \u062a\u064f\u0644\u0652\u0647\u0650\u064a\u0647\u0650\u0645\u0652 \u062a\u0650\u062c\u064e\u0670\u0631\u064e\u0629\u064c\u06ed \u0648\u064e\u0644\u064e\u0627 \u0628\u064e\u064a\u0652\u0639\u064c \u0639\u064e\u0646 \u0630\u0650\u0643\u0652\u0631\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0648\u064e\u0625\u0650\u0642\u064e\u0627\u0645\u0650 \u0671\u0644\u0635\u0651\u064e\u0644\u064e\u0648\u0670\u0629\u0650 \u0648\u064e\u0625\u0650\u064a\u062a\u064e\u0627\u0653\u0621\u0650 \u0671\u0644\u0632\u0651\u064e\u0643\u064e\u0648\u0670\u0629\u0650 \u06d9 \u064a\u064e\u062e\u064e\u0627\u0641\u064f\u0648\u0646\u064e \u064a\u064e\u0648\u0652\u0645\u064b\u06ed\u0627 \u062a\u064e\u062a\u064e\u0642\u064e\u0644\u0651\u064e\u0628\u064f \u0641\u0650\u064a\u0647\u0650 \u0671\u0644\u0652\u0642\u064f\u0644\u064f\u0648\u0628\u064f \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0628\u0652\u0635\u064e\u0670\u0631\u064f","j":18,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0646\u0651\u064f\u0648\u0631\u0650"},{"s":24,"n":38,"t":"\u0644\u0650\u064a\u064e\u062c\u0652\u0632\u0650\u064a\u064e\u0647\u064f\u0645\u064f \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0623\u064e\u062d\u0652\u0633\u064e\u0646\u064e \u0645\u064e\u0627 \u0639\u064e\u0645\u0650\u0644\u064f\u0648\u0627\u06df \u0648\u064e\u064a\u064e\u0632\u0650\u064a\u062f\u064e\u0647\u064f\u0645 \u0645\u0651\u0650\u0646 \u0641\u064e\u0636\u0652\u0644\u0650\u0647\u0650\u06e6 \u06d7 \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u064a\u064e\u0631\u0652\u0632\u064f\u0642\u064f \u0645\u064e\u0646 \u064a\u064e\u0634\u064e\u0627\u0653\u0621\u064f \u0628\u0650\u063a\u064e\u064a\u0652\u0631\u0650 \u062d\u0650\u0633\u064e\u0627\u0628\u064d\u06e2","j":18},{"s":24,"n":39,"t":"\u0648\u064e\u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0643\u064e\u0641\u064e\u0631\u064f\u0648\u0653\u0627\u06df \u0623\u064e\u0639\u0652\u0645\u064e\u0670\u0644\u064f\u0647\u064f\u0645\u0652 \u0643\u064e\u0633\u064e\u0631\u064e\u0627\u0628\u064d\u06ed \u0628\u0650\u0642\u0650\u064a\u0639\u064e\u0629\u064d\u06e2 \u064a\u064e\u062d\u0652\u0633\u064e\u0628\u064f\u0647\u064f \u0671\u0644\u0638\u0651\u064e\u0645\u0652\u0640\u0654\u064e\u0627\u0646\u064f \u0645\u064e\u0627\u0653\u0621\u064b \u062d\u064e\u062a\u0651\u064e\u0649\u0670\u0653 \u0625\u0650\u0630\u064e\u0627 \u062c\u064e\u0627\u0653\u0621\u064e\u0647\u064f\u06e5 \u0644\u064e\u0645\u0652 \u064a\u064e\u062c\u0650\u062f\u0652\u0647\u064f \u0634\u064e\u064a\u0652\u0640\u0654\u064b\u06ed\u0627 \u0648\u064e\u0648\u064e\u062c\u064e\u062f\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u0639\u0650\u0646\u062f\u064e\u0647\u064f\u06e5 \u0641\u064e\u0648\u064e\u0641\u0651\u064e\u0649\u0670\u0647\u064f \u062d\u0650\u0633\u064e\u0627\u0628\u064e\u0647\u064f\u06e5 \u06d7 \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0633\u064e\u0631\u0650\u064a\u0639\u064f \u0671\u0644\u0652\u062d\u0650\u0633\u064e\u0627\u0628\u0650","j":18},{"s":24,"n":40,"t":"\u0623\u064e\u0648\u0652 \u0643\u064e\u0638\u064f\u0644\u064f\u0645\u064e\u0670\u062a\u064d\u06e2 \u0641\u0650\u0649 \u0628\u064e\u062d\u0652\u0631\u064d\u06e2 \u0644\u0651\u064f\u062c\u0651\u0650\u0649\u0651\u064d\u06e2 \u064a\u064e\u063a\u0652\u0634\u064e\u0649\u0670\u0647\u064f \u0645\u064e\u0648\u0652\u062c\u064c\u06ed \u0645\u0651\u0650\u0646 \u0641\u064e\u0648\u0652\u0642\u0650\u0647\u0650\u06e6 \u0645\u064e\u0648\u0652\u062c\u064c\u06ed \u0645\u0651\u0650\u0646 \u0641\u064e\u0648\u0652\u0642\u0650\u0647\u0650\u06e6 \u0633\u064e\u062d\u064e\u0627\u0628\u064c\u06ed \u06da \u0638\u064f\u0644\u064f\u0645\u064e\u0670\u062a\u064c\u06e2 \u0628\u064e\u0639\u0652\u0636\u064f\u0647\u064e\u0627 \u0641\u064e\u0648\u0652\u0642\u064e \u0628\u064e\u0639\u0652\u0636\u064d \u0625\u0650\u0630\u064e\u0627\u0653 \u0623\u064e\u062e\u0652\u0631\u064e\u062c\u064e \u064a\u064e\u062f\u064e\u0647\u064f\u06e5 \u0644\u064e\u0645\u0652 \u064a\u064e\u0643\u064e\u062f\u0652 \u064a\u064e\u0631\u064e\u0649\u0670\u0647\u064e\u0627 \u06d7 \u0648\u064e\u0645\u064e\u0646 \u0644\u0651\u064e\u0645\u0652 \u064a\u064e\u062c\u0652\u0639\u064e\u0644\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0644\u064e\u0647\u064f\u06e5 \u0646\u064f\u0648\u0631\u064b\u06ed\u0627 \u0641\u064e\u0645\u064e\u0627 \u0644\u064e\u0647\u064f\u06e5 \u0645\u0650\u0646 \u0646\u0651\u064f\u0648\u0631\u064d","j":18},{"s":24,"n":41,"t":"\u0623\u064e\u0644\u064e\u0645\u0652 \u062a\u064e\u0631\u064e \u0623\u064e\u0646\u0651\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u064a\u064f\u0633\u064e\u0628\u0651\u0650\u062d\u064f \u0644\u064e\u0647\u064f\u06e5 \u0645\u064e\u0646 \u0641\u0650\u0649 \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u0648\u064e\u0671\u0644\u0637\u0651\u064e\u064a\u0652\u0631\u064f \u0635\u064e\u0670\u0653\u0641\u0651\u064e\u0670\u062a\u064d\u06e2 \u06d6 \u0643\u064f\u0644\u0651\u064c\u06ed \u0642\u064e\u062f\u0652 \u0639\u064e\u0644\u0650\u0645\u064e \u0635\u064e\u0644\u064e\u0627\u062a\u064e\u0647\u064f\u06e5 \u0648\u064e\u062a\u064e\u0633\u0652\u0628\u0650\u064a\u062d\u064e\u0647\u064f\u06e5 \u06d7 \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0639\u064e\u0644\u0650\u064a\u0645\u064c\u06e2 \u0628\u0650\u0645\u064e\u0627 \u064a\u064e\u0641\u0652\u0639\u064e\u0644\u064f\u0648\u0646\u064e","j":18},{"s":24,"n":42,"t":"\u0648\u064e\u0644\u0650\u0644\u0651\u064e\u0647\u0650 \u0645\u064f\u0644\u0652\u0643\u064f \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u06d6 \u0648\u064e\u0625\u0650\u0644\u064e\u0649 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0652\u0645\u064e\u0635\u0650\u064a\u0631\u064f","j":18},{"s":24,"n":43,"t":"\u0623\u064e\u0644\u064e\u0645\u0652 \u062a\u064e\u0631\u064e \u0623