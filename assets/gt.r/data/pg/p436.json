70\u0653\u0623\u064e\u064a\u0651\u064f\u0647\u064e\u0627 \u0671\u0644\u0646\u0651\u064e\u0627\u0633\u064f \u0623\u064e\u0646\u062a\u064f\u0645\u064f \u0671\u0644\u0652\u0641\u064f\u0642\u064e\u0631\u064e\u0627\u0653\u0621\u064f \u0625\u0650\u0644\u064e\u0649 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u06d6 \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0647\u064f\u0648\u064e \u0671\u0644\u0652\u063a\u064e\u0646\u0650\u0649\u0651\u064f \u0671\u0644\u0652\u062d\u064e\u0645\u0650\u064a\u062f\u064f","j":22},{"s":35,"n":16,"t":"\u0625\u0650\u0646 \u064a\u064e\u0634\u064e\u0623\u0652 \u064a\u064f\u0630\u0652\u0647\u0650\u0628\u0652\u0643\u064f\u0645\u0652 \u0648\u064e\u064a\u064e\u0623\u0652\u062a\u0650 \u0628\u0650\u062e\u064e\u0644\u0652\u0642\u064d\u06e2 \u062c\u064e\u062f\u0650\u064a\u062f\u064d\u06e2","j":22},{"s":35,"n":17,"t":"\u0648\u064e\u0645\u064e\u0627 \u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0639\u064e\u0644\u064e\u0649 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0628\u0650\u0639\u064e\u0632\u0650\u064a\u0632\u064d\u06e2","j":22},{"s":35,"n":18,"t":"\u0648\u064e\u0644\u064e\u0627 \u062a\u064e\u0632\u0650\u0631\u064f \u0648\u064e\u0627\u0632\u0650\u0631\u064e\u0629\u064c\u06ed \u0648\u0650\u0632\u0652\u0631\u064e \u0623\u064f\u062e\u0652\u0631\u064e\u0649\u0670 \u06da \u0648\u064e\u0625\u0650\u0646 \u062a\u064e\u062f\u0652\u0639\u064f \u0645\u064f\u062b\u0652\u0642\u064e\u0644\u064e\u0629\u064c \u0625\u0650\u0644\u064e\u0649\u0670 \u062d\u0650\u0645\u0652\u0644\u0650\u0647\u064e\u0627 \u0644\u064e\u0627 \u064a\u064f\u062d\u0652\u0645\u064e\u0644\u0652 \u0645\u0650\u0646\u0652\u0647\u064f \u0634\u064e\u0649\u0652\u0621\u064c\u06ed \u0648\u064e\u0644\u064e\u0648\u0652 \u0643\u064e\u0627\u0646\u064e \u0630\u064e\u0627 \u0642\u064f\u0631\u0652\u0628\u064e\u0649\u0670\u0653 \u06d7 \u0625\u0650\u0646\u0651\u064e\u0645\u064e\u0627 \u062a\u064f\u0646\u0630\u0650\u0631\u064f \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u064a\u064e\u062e\u0652