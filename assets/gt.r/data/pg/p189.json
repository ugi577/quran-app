":20,"t":"\u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0621\u064e\u0627\u0645\u064e\u0646\u064f\u0648\u0627\u06df \u0648\u064e\u0647\u064e\u0627\u062c\u064e\u0631\u064f\u0648\u0627\u06df \u0648\u064e\u062c\u064e\u0670\u0647\u064e\u062f\u064f\u0648\u0627\u06df \u0641\u0650\u0649 \u0633\u064e\u0628\u0650\u064a\u0644\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0628\u0650\u0623\u064e\u0645\u0652\u0648\u064e\u0670\u0644\u0650\u0647\u0650\u0645\u0652 \u0648\u064e\u0623\u064e\u0646\u0641\u064f\u0633\u0650\u0647\u0650\u0645\u0652 \u0623\u064e\u0639\u0652\u0638\u064e\u0645\u064f \u062f\u064e\u0631\u064e\u062c\u064e\u0629\u064b \u0639\u0650\u0646\u062f\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u06da \u0648\u064e\u0623\u064f\u0648\u06df\u0644\u064e\u0670\u0653\u0626\u0650\u0643\u064e \u0647\u064f\u0645\u064f \u0671\u0644\u0652\u0641\u064e\u0627\u0653\u0626\u0650\u0632\u064f\u0648\u0646\u064e","j":10}]