[{"s":45,"n":23,"t":"\u0623\u064e\u0641\u064e\u0631\u064e\u0621\u064e\u064a\u0652\u062a\u064e \u0645\u064e\u0646\u0650 \u0671\u062a\u0651\u064e\u062e\u064e\u0630\u064e \u0625\u0650\u0644\u064e\u0670\u0647\u064e\u0647\u064f\u06e5 \u0647\u064e\u0648\u064e\u0649\u0670\u0647\u064f \u0648\u064e\u0623\u064e\u0636\u064e\u0644\u0651\u064e\u0647\u064f \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0639\u064e\u0644\u064e\u0649\u0670 \u0639\u0650\u0644\u0652\u0645\u064d\u06e2 \u0648\u064e\u062e\u064e\u062a\u064e\u0645\u064e \u0639\u064e\u0644\u064e\u0649\u0670 \u0633\u064e\u0645\u0652\u0639\u0650\u0647\u0650\u06e6 \u0648\u064e\u0642\u064e\u0644\u0652\u0628\u0650\u0647\u0650\u06e6 \u0648\u064e\u062c\u064e\u0639\u064e\u0644\u064e \u0639\u064e\u0644\u064e\u0649\u0670 \u0628\u064e\u0635\u064e\u0631\u0650\u0647\u0650\u06e6 \u063a\u0650\u0634\u064e\u0670\u0648\u064e\u0629\u064b\u06ed \u0641\u064e\u0645\u064e\u0646 \u064a\u064e\u0647\u0652\u062f\u0650\u064a\u0647\u0650 \u0645\u0650\u0646\u06e2 \u0628\u064e\u0639\u0652\u062f\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u06da \u0623\u064e\u0641\u064e\u0644\u064e\u0627 \u062a\u064e\u0630\u064e\u0643\u0651\u064e\u0631\u064f\u0648\u0646\u064e","j":25,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u062c\u064e\u0627\u062b\u0650\u064a\u064e\u0629\u0650"},{"s":45,"n":24,"t":"\u0648\u064e\u0642\u064e\u0627\u0644\u064f\u0648\u0627\u06df \u0645\u064e\u0627 \u0647\u0650\u0649\u064e \u0625\u0650\u0644\u0651\u064e\u0627 \u062d\u064e\u064a\u064e\u0627\u062a\u064f\u0646\u064e\u0627 \u0671\u0644\u062f\u0651\u064f\u0646\u0652\u064a\u064e\u0627 \u0646\u064e\u0645\u064f\u0648\u062a\u064f \u0648\u064e\u0646\u064e\u062d\u0652\u064a\u064e\u0627 \u0648\u064e\u0645\u064e\u0627 \u064a\u064f\u0647\u0652\u0644\u0650\u0643\u064f\u0646\u064e\u0627\u0653 \u0625\u0650\u0644\u0651\u064e\u0627 \u0671\u0644\u062f\u0651\u064e\u0647\u0652\u0631\u064f \u06da \u0648\u064e\u0645\u064e\u0627 \u0644\u064e\u0647\u064f\u0645 \u0628\u0650\u0630\u064e\u0670\u064