[{"s":48,"n":16,"t":"\u0642\u064f\u0644 \u0644\u0651\u0650\u0644\u0652\u0645\u064f\u062e\u064e\u0644\u0651\u064e\u0641\u0650\u064a\u0646\u064e \u0645\u0650\u0646\u064e \u0671\u0644\u0652\u0623\u064e\u0639\u0652\u0631\u064e\u0627\u0628\u0650 \u0633\u064e\u062a\u064f\u062f\u0652\u0639\u064e\u0648\u0652\u0646\u064e \u0625\u0650\u0644\u064e\u0649\u0670 \u0642\u064e\u0648\u0652\u0645\u064d \u0623\u064f\u0648\u06df\u0644\u0650\u0649 \u0628\u064e\u0623\u0652\u0633\u064d\u06e2 \u0634\u064e\u062f\u0650\u064a\u062f\u064d\u06e2 \u062a\u064f\u0642\u064e\u0670\u062a\u0650\u0644\u064f\u0648\u0646\u064e\u0647\u064f\u0645\u0652 \u0623\u064e\u0648\u0652 \u064a\u064f\u0633\u0652\u0644\u0650\u0645\u064f\u0648\u0646\u064e \u06d6 \u0641\u064e\u0625\u0650\u0646 \u062a\u064f\u0637\u0650\u064a\u0639\u064f\u0648\u0627\u06df \u064a\u064f\u0624\u0652\u062a\u0650\u0643\u064f\u0645\u064f \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0623\u064e\u062c\u0652\u0631\u064b\u0627 \u062d\u064e\u0633\u064e\u0646\u064b\u06ed\u0627 \u06d6 \u0648\u064e\u0625\u0650\u0646 \u062a\u064e\u062a\u064e\u0648\u064e\u0644\u0651\u064e\u0648\u0652\u0627\u06df \u0643\u064e\u0645\u064e\u0627 \u062a\u064e\u0648\u064e\u0644\u0651\u064e\u064a\u0652\u062a\u064f\u0645 \u0645\u0651\u0650\u0646 \u0642\u064e\u0628\u0652\u0644\u064f \u064a\u064f\u0639\u064e\u0630\u0651\u0650\u0628\u0652\u0643\u064f\u0645\u0652 \u0639\u064e\u0630\u064e\u0627\u0628\u064b\u0627 \u0623\u064e\u0644\u0650\u064a\u0645\u064b\u06ed\u0627","j":26,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0641\u064e\u062a\u06e1\u062d\u0650"},{"s":48,"n":17,"t":"\u0644\u0651\u064e\u064a\u0652\u0633\u064e \u0639\u064e\u0644\u064e\u0649 \u0671\u0644\u0652\u0623\u064e\u0639\u0652\u0645\u064e\u0649\u0670 \u062d\u064e\u0631\u064e\u062c\u064c\u06ed \u0648\u064e\u0644\u064e\u0627 \u0639\u064e\u0644\u064e\u0649 \u0671\u0644\u0652\u0623\u064e\u0639\u0652\u0631\u064e\u062c\u0650 \u062d\u064e\u0631\u064e\u062c\u064c\u06ed \u0648\u064e\u0644\u064e\u0627 \u0639\u064e