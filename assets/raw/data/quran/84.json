{"n":84,"na":"الانشقاق","nl":"Al-Insyiqaq","tt":"Mekah","ja":25,"ay":[{"n":1,"a":"اِذَا السَّمَاۤءُ انْشَقَّتْۙ "},{"n":2,"a":"وَاَذِنَتْ لِرَبِّهَا وَحُقَّتْۙ "},{"n":3,"a":"وَاِذَا الْاَرْضُ مُدَّتْۙ "},{"n":4,"a":"وَاَلْقَتْ مَا فِيْهَا وَتَخَلَّتْۙ "},{"n":5,"a":"وَاَذِنَتْ لِرَبِّهَا وَحُقَّتْۗ "},{"n":6,"a":"يٰٓاَيُّهَا الْاِنْسَانُ اِنَّكَ كَادِحٌ اِلٰى رَبِّكَ كَدْحًا فَمُلٰقِيْهِۚ "},{"n":7,"a":"فَاَمَّا مَنْ اُوْتِيَ كِتٰبَهٗ بِيَمِيْنِهٖۙ "},{"n":8,"a":"فَسَوْفَ يُحَاسَبُ حِسَابًا يَّسِيْرًاۙ "},{"n":9,"a":"وَّيَنْقَلِبُ اِلٰٓى اَهْلِهٖ مَسْرُوْرًاۗ "},{"n":10,"a":"وَاَمَّا مَنْ اُوْتِيَ كِتٰبَهٗ وَرَاۤءَ ظَهْرِهٖۙ "},{"n":11,"a":"فَسَوْفَ يَدْعُوْ ثُبُوْرًاۙ "},{"n":12,"a":"وَّيَصْلٰى سَعِيْرًاۗ "},{"n":13,"a":"اِنَّهٗ كَانَ فِيْٓ اَهْلِهٖ مَسْرُوْرًاۗ "},{"n":14,"a":"اِنَّهٗ ظَنَّ اَنْ لَّنْ يَّحُوْرَ ۛ "},{"n":15,"a":"بَلٰىۛ اِنَّ رَبَّهٗ كَانَ بِهٖ بَصِيْرًاۗ "},{"n":16,"a":"فَلَآ اُقْسِمُ بِالشَّفَقِۙ "},{"n":17,"a":"وَالَّيْلِ وَمَا وَسَقَۙ "},{"n":18,"a":"وَالْقَمَرِ اِذَا اتَّسَقَۙ "},{"n":19,"a":"لَتَرْكَبُنَّ طَبَقًا عَنْ طَبَقٍۗ "},{"n":20,"a":"فَمَا لَهُمْ لَا يُؤْمِنُوْنَۙ "},{"n":21,"a":"وَاِذَا قُرِئَ عَلَيْهِمُ الْقُرْاٰنُ لَا يَسْجُدُوْنَ ۗ ۩ "},{"n":22,"a":"بَلِ الَّذِيْنَ كَفَرُوْا يُكَذِّبُوْنَۖ "},{"n":23,"a":"وَاللّٰهُ اَعْلَمُ بِمَا يُوْعُوْنَۖ "},{"n":24,"a":"فَبَشِّرْهُمْ بِعَذَابٍ اَلِيْمٍۙ "},{"n":25,"a":"اِلَّا الَّذِيْنَ اٰمَنُوْا وَعَمِلُوا الصّٰلِحٰتِ لَهُمْ اَجْرٌ غَيْرُ مَمْنُوْنٍ ࣖ "}]}