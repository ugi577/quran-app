[{"s":5,"n":58,"t":"\u0648\u064e\u0625\u0650\u0630\u064e\u0627 \u0646\u064e\u0627\u062f\u064e\u064a\u0652\u062a\u064f\u0645\u0652 \u0625\u0650\u0644\u064e\u0649 \u0671\u0644\u0635\u0651\u064e\u0644\u064e\u0648\u0670\u0629\u0650 \u0671\u062a\u0651\u064e\u062e\u064e\u0630\u064f\u0648\u0647\u064e\u0627 \u0647\u064f\u0632\u064f\u0648\u064b\u06ed\u0627 \u0648\u064e\u0644\u064e\u0639\u0650\u0628\u064b\u06ed\u0627 \u06da \u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0628\u0650\u0623\u064e\u0646\u0651\u064e\u0647\u064f\u0645\u0652 \u0642\u064e\u0648\u0652\u0645\u064c\u06ed \u0644\u0651\u064e\u0627 \u064a\u064e\u0639\u0652\u0642\u0650\u0644\u064f\u0648\u0646\u064e","j":6,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0645\u064e\u0627\u0626\u0640\u0650\u062f\u064e\u0629\u0650"},{"s":5,"n":59,"t":"\u0642\u064f\u0644\u0652 \u064a\u064e\u0670\u0653\u0623\u064e\u0647\u0652\u0644\u064e \u0671\u0644\u0652\u0643\u0650\u062a\u064e\u0670\u0628\u0650 \u0647\u064e\u0644\u0652 \u062a\u064e\u0646\u0642\u0650\u0645\u064f\u0648\u0646\u064e \u0645\u0650\u0646\u0651\u064e\u0627\u0653 \u0625\u0650\u0644\u0651\u064e\u0627\u0653 \u0623\u064e\u0646\u0652 \u0621\u064e\u0627\u0645\u064e\u0646\u0651\u064e\u0627 \u0628\u0650\u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0648\u064e\u0645\u064e\u0627\u0653 \u0623\u064f\u0646\u0632\u0650\u0644\u064e \u0625\u0650\u0644\u064e\u064a\u0652\u0646\u064e\u0627 \u0648\u064e\u0645\u064e\u0627\u0653 \u0623\u064f\u0646\u0632\u0650\u0644\u064e \u0645\u0650\u0646 \u0642\u064e\u0628\u0652\u0644\u064f \u0648\u064e\u0623\u064e\u0646\u0651\u064e \u0623\u064e\u0643\u0652\u062b\u064e\u0631\u064e\u0643\u064f\u0645\u0652 \u0641\u064e\u0670\u0633\u0650\u0642\u064f\u0648\u0646\u064e","j":6},{"s":5,"n":60,"t":"\u0642\u064f\u0644\u0652 \u0647\u064e\u0644\u0652 \u0623\u064f\u0646\u064e\u0628\u0651\u0650\u0626\u064f\u0643\u064f\u0645 \u0628\u0650\u0634\u064e\u0631\u0651\u064d\u06e2 \u0645\u0651\u0650\u0646 \u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0645\u064e\u062b