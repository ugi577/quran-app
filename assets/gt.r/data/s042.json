44\u064e\u0649 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u06da \u0625\u0650\u0646\u0651\u064e\u0647\u064f\u06e5 \u0644\u064e\u0627 \u064a\u064f\u062d\u0650\u0628\u0651\u064f \u0671\u0644\u0638\u0651\u064e\u0670\u0644\u0650\u0645\u0650\u064a\u0646\u064e","p":487,"j":25},{"n":41,"t":"\u0648\u064e\u0644\u064e\u0645\u064e\u0646\u0650 \u0671\u0646\u062a\u064e\u0635\u064e\u0631\u064e \u0628\u064e\u0639\u0652\u062f\u064e \u0638\u064f\u0644\u0652\u0645\u0650\u0647\u0650\u06e6 \u0641\u064e\u0623\u064f\u0648\u06df\u0644\u064e\u0670\u0653\u0626\u0650\u0643\u064e \u0645\u064e\u0627 \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650\u0645 \u0645\u0651\u0650\u0646 \u0633\u064e\u0628\u0650\u064a\u0644\u064d","p":487,"j":25},{"n":42,"t":"\u0625\u0650\u0646\u0651\u064e\u0645\u064e\u0627 \u0671\u0644\u0633\u0651\u064e\u0628\u0650\u064a\u0644\u064f \u0639\u064e\u0644\u064e\u0649 \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u064a\u064e\u0638\u0652\u0644\u0650\u0645\u064f\u0648\u0646\u064e \u0671\u0644\u0646\u0651\u064e\u0627\u0633\u064e \u0648\u064e\u064a\u064e\u0628\u0652\u063a\u064f\u0648\u0646\u064e \u0641\u0650\u0649 \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u0628\u0650\u063a\u064e\u064a\u0652\u0631\u0650 \u0671\u0644\u0652\u062d\u064e\u0642\u0651\u0650 \u06da \u0623\u064f\u0648\u06df\u0644\u064e\u0670\u0653\u0626\u0650\u0643\u064e \u0644\u064e\u0647\u064f\u0645\u0652 \u0639\u064e\u0630\u064e\u0627\u0628\u064c \u0623\u064e\u0644\u0650\u064a\u0645\u064c\u06ed","p":487,"j":25},{"n":43,"t":"\u0648\u064e\u0644\u064e\u0645\u064e\u0646 \u0635\u064e\u0628\u064e\u0631\u064e \u0648\u064e\u063a\u064e\u0641\u064e\u0631\u064e \u0625\u0650\u0646\u0651\u064e \u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0644\u064e\u0645\u0650\u0646\u0652 \u0639\u064e\u0632\u0652\u0645\u0650 \u0671\u0644\u0652\u0623\u064f\u0645\u064f\u0648\u0631\u0650","p":487,"j":25},{"n":44,"t":"\u0648\u064e\u0645\u064e\u0646 \u064a\u064f\u0636\u0652\u0644\u0650\u0644\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0641\u064e\u0645\u064e\u0627 \u0644\u064e\u0647\u064f\u06e5 \u0645\u0650\u0646 \u0648\u064e\u0644\u0650\u0649\u0651\u064d\u06e2 \u0645\u0651\u0650\u0646\u06e2 \u0628\u064e\u0639\u0652\u062f\u0650\u0647\u0650\u06e6 \u06d7 \u0648\u064e\u062a\u064e\u0631\u064e\u0649 \u0671\u0644\u0638\u0651\u064e\u0670\u0644\u0650\u0645\u0650\u064a\u0646\u064e \u0644\u064e\u0645\u0651\u064e\u0627 \u0631\u064e\u0623\u064e\u0648\u064f\u0627\u06df \u0671\u0644\u0652\u0639\u064e\u0630\u064e\u0627\u0628\u064e \u064a\u064e\u0642\u064f\u0648\u0644\u064f\u0648\u0646\u064e \u0647\u064e\u0644\u0652 \u0625\u0650\u0644\u064e\u0649\u0670 \u0645\u064e\u0631\u064e\u062f\u0651\u064d\u06e2 \u0645\u0651\u0650\u0646 \u0633\u064e\u0628\u0650\u064a\u0644\u064d\u06e2","p":487,"j":25},{"n":45,"t":"\u0648\u064e\u062a\u064e\u0631\u064e\u0649\u0670\u0647\u064f\u0645\u0652 \u064a\u064f\u0639\u0652\u0631\u064e\u0636\u064f\u0648\u0646\u064e \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u064e\u0627 \u062e\u064e\u0670\u0634\u0650\u0639\u0650\u064a\u0646\u064e \u0645\u0650\u0646\u064e \u0671\u0644\u0630\u0651\u064f\u0644\u0651\u0650 \u064a\u064e\u0646\u0638\u064f\u0631\u064f\u0648\u0646\u064e \u0645\u0650\u0646 \u0637\u064e\u0631\u0652\u0641\u064d \u062e\u064e\u0641\u0650\u0649\u0651\u064d\u06e2 \u06d7 \u0648\u064e\u0642\u064e\u0627\u0644\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0621\u064e\u0627\u0645\u064e\u0646\u064f\u0648\u0653\u0627\u06df \u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0652\u062e\u064e\u0670\u0633\u0650\u0631\u0650\u064a\u0646\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u062e\u064e\u0633\u0650\u0631\u064f\u0648\u0653\u0627\u06df \u0623\u064e\u0646\u0641\u064f\u0633\u064e\u0647\u064f\u0645\u0652 \u0648\u064e\u0623\u064e\u0647\u0652\u0644\u0650\u064a\u0647\u0650\u0645\u0652 \u064a\u064e\u0648\u0652\u0645\u064e \u0671\u0644\u0652\u0642\u0650\u064a\u064e\u0670\u0645\u064e\u0629\u0650 \u06d7 \u0623\u064e\u0644\u064e\u0627\u0653 \u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0638\u0651\u064e\u0670\u0644\u0650\u0645\u0650\u064a\u0646\u064e \u0641\u0650\u0649 \u0639\u064e\u0630\u064e\u0627\u0628\u064d\u06e2 \u0645\u0651\u064f\u0642\u0650\u064a\u0645\u064d\u06e2","p":488,"j":25},{"n":46,"t":"\u0648\u064e\u0645\u064e\u0627 \u0643\u064e\u0627\u0646\u064e \u0644\u064e\u0647\u064f\u0645 \u0645\u0651\u0650\u0646\u0652 \u0623\u064e\u0648\u0652\u0644\u0650\u064a\u064e\u0627\u0653\u0621\u064e \u064a\u064e\u0646\u0635\u064f\u0631\u064f\u0648\u0646\u064e\u0647\u064f\u0645 \u0645\u0651\u0650\u0646 \u062f\u064f\u0648\u0646\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u06d7 \u0648\u064e\u0645\u064e\u0646 \u064a\u064f\u0636\u0652\u0644\u0650\u0644\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0641\u064e\u0645\u064e\u0627 \u0644\u064e\u0647\u064f\u06e5 \u0645\u0650\u0646 \u0633\u064e\u0628\u0650\u064a\u0644\u064d","p":488,"j":25},{"n":47,"t":"\u0671\u0633\u0652\u062a\u064e\u062c\u0650\u064a\u0628\u064f\u0648\u0627\u06df \u0644\u0650\u0631\u064e\u0628\u0651\u0650\u0643\u064f\u0645 \u0645\u0651\u0650\u0646 \u0642\u064e\u0628\u0652\u0644\u0650 \u0623\u064e\u0646 \u064a\u064e\u0623\u0652\u062a\u0650\u0649\u064e \u064a\u064e\u0648\u0652\u0645\u064c\u06ed \u0644\u0651\u064e\u0627 \u0645\u064e\u0631\u064e\u062f\u0651\u064e \u0644\u064e\u0647\u064f\u06e5 \u0645\u0650\u0646\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u06da \u0645\u064e\u0627 \u0644\u064e\u0643\u064f\u0645 \u0645\u0651\u0650\u0646 \u0645\u0651\u064e\u0644\u0652\u062c\u064e\u0625\u064d\u06e2 \u064a\u064e\u0648\u0652\u0645\u064e\u0626\u0650\u0630\u064d\u06e2 \u0648\u064e\u0645\u064e\u0627 \u0644\u064e\u0643\u064f\u0645 \u0645\u0651\u0650\u0646 \u0646\u0651\u064e\u0643\u0650\u064a\u0631\u064d\u06e2","p":488,"j":25},{"n":48,"t":"\u0641\u064e\u0625\u0650\u0646\u0652 \u0623\u064e\u0639\u0652\u0631\u064e\u0636\u064f\u0648\u0627\u06df \u0641\u064e\u0645\u064e\u0627\u0653 \u0623\u064e\u0631\u0652\u0633\u064e\u0644\u0652\u0646\u064e\u0670\u0643\u064e \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650\u0645\u0652 \u062d\u064e\u0641\u0650\u064a\u0638\u064b\u0627 \u06d6 \u0625\u0650\u0646\u0652 \u0639\u064e\u0644\u064e\u064a\u0652\u0643\u064e \u0625\u0650\u0644\u0651\u064e\u0627 \u0671\u0644\u0652\u0628\u064e\u0644\u064e\u0670\u063a\u064f \u06d7 \u0648\u064e\u0625\u0650\u0646\u0651\u064e\u0627\u0653 \u0625\u0650\u0630\u064e\u0627\u0653 \u0623\u064e\u0630\u064e\u0642\u0652\u0646\u064e\u0627 \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064e \u0645\u0650\u0646\u0651\u064e\u0627 \u0631\u064e\u062d\u0652\u0645\u064e\u0629\u064b\u06ed \u0641\u064e\u0631\u0650\u062d\u064e \u0628\u0650\u0647\u064e\u0627 \u06d6 \u0648\u064e\u0625\u0650\u0646 \u062a\u064f\u0635\u0650\u0628\u0652\u0647\u064f\u0645\u0652 \u0633\u064e\u064a\u0651\u0650\u0626\u064e\u0629\u064c\u06e2 \u0628\u0650\u0645\u064e\u0627 \u0642\u064e\u062f\u0651\u064e\u0645\u064e\u062a\u0652 \u0623\u064e\u064a\u0652\u062f\u0650\u064a\u0647\u0650\u0645\u0652 \u0641\u064e\u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0652\u0625\u0650\u0646\u0633\u064e\u0670\u0646\u064e \u0643\u064e\u0641\u064f\u0648\u0631\u064c\u06ed","p":488,"j":25},{"n":49,"t":"\u0644\u0651\u0650\u0644\u0651\u064e\u0647\u0650 \u0645\u064f\u0644\u0652\u0643\u064f \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u06da \u064a\u064e\u062e\u0652\u0644\u064f\u0642\u064f \u0645\u064e\u0627 \u064a\u064e\u0634\u064e\u0627\u0653\u0621\u064f \u06da \u064a\u064e\u0647\u064e\u0628\u064f \u0644\u0650\u0645\u064e\u0646 \u064a\u064e\u0634\u064e\u0627\u0653\u0621\u064f \u0625\u0650\u0646\u064e\u0670\u062b\u064b\u06ed\u0627 \u0648\u064e\u064a\u064e\u0647\u064e\u0628\u064f \u0644\u0650\u0645\u064e\u0646 \u064a\u064e\u0634\u064e\u0627\u0653\u0621\u064f \u0671\u0644\u0630\u0651\u064f\u0643\u064f\u0648\u0631\u064e","p":488,"j":25},{"n":50,"t":"\u0623\u064e\u0648\u0652 \u064a\u064f\u0632\u064e\u0648\u0651\u0650\u062c\u064f\u0647\u064f\u0645\u0652 \u0630\u064f\u0643\u0652\u0631\u064e\u0627\u0646\u064b\u06ed\u0627 \u0648\u064e\u0625\u0650\u0646\u064e\u0670\u062b\u064b\u06ed\u0627 \u06d6 \u0648\u064e\u064a\u064e\u062c\u0652\u0639\u064e\u0644\u064f \u0645\u064e\u0646 \u064a\u064e\u0634\u064e\u0627\u0653\u0621\u064f \u0639\u064e\u0642\u0650\u064a\u0645\u064b\u0627 \u06da \u0625\u0650\u0646\u0651\u064e\u0647\u064f\u06e5 \u0639\u064e\u0644\u0650\u064a\u0645\u064c\u06ed \u0642\u064e\u062f\u0650\u064a\u0631\u064c\u06ed","p":488,"j":25},{"n":51,"t":"\u06de \u0648\u064e\u0645\u064e\u0627 \u0643\u064e\u0627\u0646\u064e \u0644\u0650\u0628\u064e\u0634\u064e\u0631\u064d \u0623\u064e\u0646 \u064a\u064f\u0643\u064e\u0644\u0651\u0650\u0645\u064e\u0647\u064f \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0625\u0650\u0644\u0651\u064e\u0627 \u0648\u064e\u062d\u0652\u064a\u064b\u0627 \u0623\u064e\u0648\u0652 \u0645\u0650\u0646 \u0648\u064e\u0631\u064e\u0627\u0653\u0626\u0650 \u062d\u0650\u062c\u064e\u0627\u0628\u064d \u0623\u064e\u0648\u0652 \u064a\u064f\u0631\u0652\u0633\u0650\u0644\u064e \u0631\u064e\u0633\u064f\u0648\u0644\u064b\u06ed\u0627 \u0641\u064e\u064a\u064f\u0648\u062d\u0650\u0649\u064e \u0628\u0650\u0625\u0650\u0630\u0652\u0646\u0650\u0647\u0650\u06e6 \u0645\u064e\u0627 \u064a\u064e\u0634\u064e\u0627\u0653\u0621\u064f \u06da \u0625\u0650\u0646\u0651\u064e\u0647\u064f\u06e5 \u0639\u064e\u0644\u0650\u0649\u0651\u064c \u062d\u064e\u0643\u0650\u064a\u0645\u064c\u06ed","p":488,"j":25},{"n":52,"t":"\u0648\u064e\u0643\u064e\u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0623\u064e\u0648\u0652\u062d\u064e\u064a\u0652\u0646\u064e\u0627\u0653 \u0625\u0650\u0644\u064e\u064a\u0652\u0643\u064e \u0631\u064f\u0648\u062d\u064b\u06ed\u0627 \u0645\u0651\u0650\u0646\u0652 \u0623\u064e\u0645\u0652\u0631\u0650\u0646\u064e\u0627 \u06da \u0645\u064e\u0627 \u0643\u064f\u0646\u062a\u064e \u062a\u064e\u062f\u0652\u0631\u0650\u0649 \u0645\u064e\u0627 \u0671\u0644\u0652\u0643\u0650\u062a\u064e\u0670\u0628\u064f \u0648\u064e\u0644\u064e\u0627 \u0671\u0644\u0652\u0625\u0650\u064a\u0645\u064e\u0670\u0646\u064f \u0648\u064e\u0644\u064e\u0670\u0643\u0650\u0646 \u062c\u064e\u0639\u064e\u0644\u0652\u0646\u064e\u0670\u0647\u064f \u0646\u064f\u0648\u0631\u064b\u06ed\u0627 \u0646\u0651\u064e\u0647\u0652\u062f\u0650\u0649 \u0628\u0650\u0647\u0650\u06e6 \u0645\u064e\u0646 \u0646\u0651\u064e\u0634\u064e\u0627\u0653\u0621\u064f \u0645\u0650\u0646\u0652 \u0639\u0650\u0628\u064e\u0627\u062f\u0650\u0646\u064e\u0627 \u06da \u0648\u064e\u0625\u0650\u0646\u0651\u064e\u0643\u064e \u0644\u064e\u062a\u064e\u0647\u0652\u062f\u0650\u0649\u0653 \u0625\u0650\u0644\u064e\u0649\u0670 \u0635\u0650\u0631\u064e\u0670\u0637\u064d\u06e2 \u0645\u0651\u064f\u0633\u0652\u062a\u064e\u0642\u0650\u064a\u0645\u064d\u06e2","p":489,"j":25},{"n":53,"t":"\u0635\u0650\u0631\u064e\u0670\u0637\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0651\u064e\u0630\u0650\u0649 \u0644\u064e\u0647\u064f\u06e5 \u0645\u064e\u0627 \u0641\u0650\u0649 \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0645\u064e\u0627 \u0641\u0650\u0649 \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u06d7 \u0623\u064e\u0644\u064e\u0627\u0653 \u0625\u0650\u0644\u064e\u0649 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u062a\u064e\u0635\u0650\u064a\u0631\u064f \u0671\u0644\u0652\u0623\u064f\u0645\u064f\u0648\u0631\u064f","p":489,"j":25}]}