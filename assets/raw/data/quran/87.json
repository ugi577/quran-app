{"n":87,"na":"الاعلى","nl":"Al-A'la","tt":"Mekah","ja":19,"ay":[{"n":1,"a":"سَبِّحِ اسْمَ رَبِّكَ الْاَعْلَىۙ "},{"n":2,"a":"الَّذِيْ خَلَقَ فَسَوّٰىۖ "},{"n":3,"a":"وَالَّذِيْ قَدَّرَ فَهَدٰىۖ "},{"n":4,"a":"وَالَّذِيْٓ اَخْرَجَ الْمَرْعٰىۖ "},{"n":5,"a":"فَجَعَلَهٗ غُثَاۤءً اَحْوٰىۖ "},{"n":6,"a":"سَنُقْرِئُكَ فَلَا تَنْسٰىٓ  ۖ "},{"n":7,"a":"اِلَّا مَا شَاۤءَ اللّٰهُ ۗاِنَّهٗ يَعْلَمُ الْجَهْرَ وَمَا يَخْفٰىۗ "},{"n":8,"a":"وَنُيَسِّرُكَ لِلْيُسْرٰىۖ "},{"n":9,"a":"فَذَكِّرْ اِنْ نَّفَعَتِ الذِّكْرٰىۗ "},{"n":10,"a":"سَيَذَّكَّرُ مَنْ يَّخْشٰىۙ "},{"n":11,"a":"وَيَتَجَنَّبُهَا الْاَشْقَىۙ "},{"n":12,"a":"الَّذِيْ يَصْلَى النَّارَ الْكُبْرٰىۚ "},{"n":13,"a":"ثُمَّ لَا يَمُوْتُ فِيْهَا وَلَا يَحْيٰىۗ "},{"n":14,"a":"قَدْ اَفْلَحَ مَنْ تَزَكّٰىۙ "},{"n":15,"a":"وَذَكَرَ اسْمَ رَبِّهٖ فَصَلّٰىۗ "},{"n":16,"a":"بَلْ تُؤْثِرُوْنَ الْحَيٰوةَ الدُّنْيَاۖ "},{"n":17,"a":"وَالْاٰخِرَةُ خَيْرٌ وَّاَبْقٰىۗ "},{"n":18,"a":"اِنَّ هٰذَا لَفِى الصُّحُفِ الْاُوْلٰىۙ "},{"n":19,"a":"صُحُفِ اِبْرٰهِيْمَ وَمُوْسٰى ࣖ "}]}