[{"s":22,"n":24,"t":"\u0648\u064e\u0647\u064f\u062f\u064f\u0648\u0653\u0627\u06df \u0625\u0650\u0644\u064e\u0649 \u0671\u0644\u0637\u0651\u064e\u064a\u0651\u0650\u0628\u0650 \u0645\u0650\u0646\u064e \u0671\u0644\u0652\u0642\u064e\u0648\u0652\u0644\u0650 \u0648\u064e\u0647\u064f\u062f\u064f\u0648\u0653\u0627\u06df \u0625\u0650\u0644\u064e\u0649\u0670 \u0635\u0650\u0631\u064e\u0670\u0637\u0650 \u0671\u0644\u0652\u062d\u064e\u0645\u0650\u064a\u062f\u0650","j":17,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u062d\u064e\u062c\u0651\u0650"},{"s":22,"n":25,"t":"\u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0643\u064e\u0641\u064e\u0631\u064f\u0648\u0627\u06df \u0648\u064e\u064a\u064e\u0635\u064f\u062f\u0651\u064f\u0648\u0646\u064e \u0639\u064e\u0646 \u0633\u064e\u0628\u0650\u064a\u0644\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0648\u064e\u0671\u0644\u0652\u0645\u064e\u0633\u0652\u062c\u0650\u062f\u0650 \u0671\u0644\u0652\u062d\u064e\u0631\u064e\u0627\u0645\u0650 \u0671\u0644\u0651\u064e\u0630\u0650\u0649 \u062c\u064e\u0639\u064e\u0644\u0652\u0646\u064e\u0670\u0647\u064f \u0644\u0650\u0644\u0646\u0651\u064e\u0627\u0633\u0650 \u0633\u064e\u0648\u064e\u0627\u0653\u0621\u064b \u0671\u0644\u0652\u0639\u064e\u0670\u0643\u0650\u0641\u064f \u0641\u0650\u064a\u0647\u0650 \u0648\u064e\u0671\u0644\u0652\u0628\u064e\u0627\u062f\u0650 \u06da \u0648\u064e\u0645\u064e\u0646 \u064a\u064f\u0631\u0650\u062f\u0652 \u0641\u0650\u064a\u0647\u0650 \u0628\u0650\u0625\u0650\u0644\u0652\u062d\u064e\u0627\u062f\u064d\u06ed \u0628\u0650\u0638\u064f\u0644\u0652\u0645\u064d\u06e2 \u0646\u0651\u064f\u0630\u0650\u0642\u0652\u0647\u064f \u0645\u0650\u0646\u0652 \u0639\u064e\u0630\u064e\u0627\u0628\u064d \u0623\u064e\u0644\u0650\u064a\u0645\u064d\u06e2","j":17},{"s":22,"n":26,"t":"\u0648\u064e\u0625\u0650\u0630\u0652 \u0628\u064e\u0648\u0651\u064e\u0623\u0652\u0646\u064e\u0627 \u0644\u0650\u0625\u0650\u0628\u0652\u0631\u064e\u0670\u0647\u0