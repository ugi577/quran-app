{"n":82,"na":"الانفطار","nl":"Al-Infitar","tt":"Mekah","ja":19,"ay":[{"n":1,"a":"اِذَا السَّمَاۤءُ انْفَطَرَتْۙ"},{"n":2,"a":"وَاِذَا الْكَوَاكِبُ انْتَثَرَتْۙ"},{"n":3,"a":"وَاِذَا الْبِحَارُ فُجِّرَتْۙ"},{"n":4,"a":"وَاِذَا الْقُبُوْرُ بُعْثِرَتْۙ"},{"n":5,"a":"عَلِمَتْ نَفْسٌ مَّا قَدَّمَتْ وَاَخَّرَتْۗ"},{"n":6,"a":"يٰٓاَيُّهَا الْاِنْسَانُ مَا غَرَّكَ بِرَبِّكَ الْكَرِيْمِۙ"},{"n":7,"a":"الَّذِيْ خَلَقَكَ فَسَوّٰىكَ فَعَدَلَكَۙ"},{"n":8,"a":"فِيْٓ اَيِّ صُوْرَةٍ مَّا شَاۤءَ رَكَّبَكَۗ"},{"n":9,"a":"كَلَّا بَلْ تُكَذِّبُوْنَ بِالدِّيْنِۙ"},{"n":10,"a":"وَاِنَّ عَلَيْكُمْ لَحٰفِظِيْنَۙ"},{"n":11,"a":"كِرَامًا كَاتِبِيْنَۙ"},{"n":12,"a":"يَعْلَمُوْنَ مَا تَفْعَلُوْنَ"},{"n":13,"a":"اِنَّ الْاَبْرَارَ لَفِيْ نَعِيْمٍۙ"},{"n":14,"a":"وَّاِنَّ الْفُجَّارَ لَفِيْ جَحِيْمٍ"},{"n":15,"a":"يَصْلَوْنَهَا يَوْمَ الدِّيْنِ"},{"n":16,"a":"وَمَا هُمْ عَنْهَا بِغَاۤىِٕبِيْنَۗ"},{"n":17,"a":"وَمَآ اَدْرٰىكَ مَا يَوْمُ الدِّيْنِۙ"},{"n":18,"a":"ثُمَّ مَآ اَدْرٰىكَ مَا يَوْمُ الدِّيْنِۗ"},{"n":19,"a":"يَوْمَ لَا تَمْلِكُ نَفْسٌ لِّنَفْسٍ شَيْـًٔا ۗوَالْاَمْرُ يَوْمَىِٕذٍ لِّلّٰهِ ࣖ"}]}