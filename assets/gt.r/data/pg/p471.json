[{"s":40,"n":34,"t":"\u0648\u064e\u0644\u064e\u0642\u064e\u062f\u0652 \u062c\u064e\u0627\u0653\u0621\u064e\u0643\u064f\u0645\u0652 \u064a\u064f\u0648\u0633\u064f\u0641\u064f \u0645\u0650\u0646 \u0642\u064e\u0628\u0652\u0644\u064f \u0628\u0650\u0671\u0644\u0652\u0628\u064e\u064a\u0651\u0650\u0646\u064e\u0670\u062a\u0650 \u0641\u064e\u0645\u064e\u0627 \u0632\u0650\u0644\u0652\u062a\u064f\u0645\u0652 \u0641\u0650\u0649 \u0634\u064e\u0643\u0651\u064d\u06e2 \u0645\u0651\u0650\u0645\u0651\u064e\u0627 \u062c\u064e\u0627\u0653\u0621\u064e\u0643\u064f\u0645 \u0628\u0650\u0647\u0650\u06e6 \u06d6 \u062d\u064e\u062a\u0651\u064e\u0649\u0670\u0653 \u0625\u0650\u0630\u064e\u0627 \u0647\u064e\u0644\u064e\u0643\u064e \u0642\u064f\u0644\u0652\u062a\u064f\u0645\u0652 \u0644\u064e\u0646 \u064a\u064e\u0628\u0652\u0639\u064e\u062b\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0645\u0650\u0646\u06e2 \u0628\u064e\u0639\u0652\u062f\u0650\u0647\u0650\u06e6 \u0631\u064e\u0633\u064f\u0648\u0644\u064b\u06ed\u0627 \u06da \u0643\u064e\u0630\u064e\u0670\u0644\u0650\u0643\u064e \u064a\u064f\u0636\u0650\u0644\u0651\u064f \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0645\u064e\u0646\u0652 \u0647\u064f\u0648\u064e \u0645\u064f\u0633\u0652\u0631\u0650\u0641\u064c\u06ed \u0645\u0651\u064f\u0631\u0652\u062a\u064e\u0627\u0628\u064c","j":24,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u063a\u064e\u0627\u0641\u0650\u0631\u064d"},{"s":40,"n":35,"t":"\u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u064a\u064f\u062c\u064e\u0670\u062f\u0650\u0644\u064f\u0648\u0646\u064e \u0641\u0650\u0649\u0653 \u0621\u064e\u0627\u064a\u064e\u0670\u062a\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0628\u0650\u063a\u064e\u064a\u0652\u0631\u0650 \u0633\u064f\u0644\u0652\u0637\u064e\u0670\u0646\u064d \u0623\u064e\u062a\u064e\u0649\u0670\u0647\u064f\u0645\u0652 \u06d6 \u0643\u064e\u0628\u064f\u0631\u064e \u0645\u064e\u0642\u0652\u062a\u064b\u0627 \u0639\u0650\u0646\u062f\u064e \u0671\u0644\u0644\u0651\u064e\