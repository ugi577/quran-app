[{"s":30,"n":6,"t":"\u0648\u064e\u0639\u0652\u062f\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u06d6 \u0644\u064e\u0627 \u064a\u064f\u062e\u0652\u0644\u0650\u0641\u064f \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0648\u064e\u0639\u0652\u062f\u064e\u0647\u064f\u06e5 \u0648\u064e\u0644\u064e\u0670\u0643\u0650\u0646\u0651\u064e \u0623\u064e\u0643\u0652\u062b\u064e\u0631\u064e \u0671\u0644\u0646\u0651\u064e\u0627\u0633\u0650 \u0644\u064e\u0627 \u064a\u064e\u0639\u0652\u0644\u064e\u0645\u064f\u0648\u0646\u064e","j":21,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0631\u0651\u064f\u0648\u0645\u0650"},{"s":30,"n":7,"t":"\u064a\u064e\u0639\u0652\u0644\u064e\u0645\u064f\u0648\u0646\u064e \u0638\u064e\u0670\u0647\u0650\u0631\u064b\u06ed\u0627 \u0645\u0651\u0650\u0646\u064e \u0671\u0644\u0652\u062d\u064e\u064a\u064e\u0648\u0670\u0629\u0650 \u0671\u0644\u062f\u0651\u064f\u0646\u0652\u064a\u064e\u0627 \u0648\u064e\u0647\u064f\u0645\u0652 \u0639\u064e\u0646\u0650 \u0671\u0644\u0652\u0621\u064e\u0627\u062e\u0650\u0631\u064e\u0629\u0650 \u0647\u064f\u0645\u0652 \u063a\u064e\u0670\u0641\u0650\u0644\u064f\u0648\u0646\u064e","j":21},{"s":30,"n":8,"t":"\u0623\u064e\u0648\u064e\u0644\u064e\u0645\u0652 \u064a\u064e\u062a\u064e\u0641\u064e\u0643\u0651\u064e\u0631\u064f\u0648\u0627\u06df \u0641\u0650\u0649\u0653 \u0623\u064e\u0646\u0641\u064f\u0633\u0650\u0647\u0650\u0645 \u06d7 \u0645\u0651\u064e\u0627 \u062e\u064e\u0644\u064e\u0642\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u064e \u0648\u064e\u0645\u064e\u0627 \u0628\u064e\u064a\u0652\u0646\u064e\u0647\u064f\u0645\u064e\u0627\u0653 \u0625\u0650\u0644\u0651\u064e\u0627 \u0628\u0650\u0671\u0644\u0652\u062d\u064e\u0642\u0651\u0650 \u0648\u064e\u0623\u064e\u062c\u064e\u0644\u064d\u06e2 \u0645\u0651\u064f\u0633\u064e\u0645\u0651\u064b\u06ed\u0649 \u06d7 \u0648\u064e\u0625\u06