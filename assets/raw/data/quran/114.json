{"nomor":114,"nama":"الناس","namaLatin":"An-Nas","tempatTurun":"Mekah","jumlahAyat":6,"ayat":[{"nomor":1,"arab":"قُلْ اَعُوْذُ بِرَبِّ النَّاسِۙ","terjemah":"Katakanlah, “Aku berlindung kepada Tuhannya manusia,"},{"nomor":2,"arab":"مَلِكِ النَّاسِۙ","terjemah":"Raja manusia,"},{"nomor":3,"arab":"اِلٰهِ النَّاسِۙ","terjemah":"sembahan manusia,"},{"nomor":4,"arab":"مِنْ شَرِّ الْوَسْوَاسِ ەۙ الْخَنَّاسِۖ","terjemah":"dari kejahatan (bisikan) setan yang bersembunyi,"},{"nomor":5,"arab":"الَّذِيْ يُوَسْوِسُ فِيْ صُدُوْرِ النَّاسِۙ","terjemah":"yang membisikkan (kejahatan) ke dalam dada manusia,"},{"nomor":6,"arab":"مِنَ الْجِنَّةِ وَالنَّاسِ ࣖ ","terjemah":"dari (golongan) jin dan manusia.”"}]}