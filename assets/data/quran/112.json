{"nomor":112,"nama":"الاخلاص","namaLatin":"Al-Ikhlas","tempatTurun":"Mekah","jumlahAyat":4,"ayat":[{"nomor":1,"arab":"قُلْ هُوَ اللّٰهُ اَحَدٌۚ","terjemah":"Katakanlah (Muhammad), “Dialah Allah, Yang Maha Esa."},{"nomor":2,"arab":"اَللّٰهُ الصَّمَدُۚ","terjemah":"Allah tempat meminta segala sesuatu."},{"nomor":3,"arab":"لَمْ يَلِدْ وَلَمْ يُوْلَدْۙ","terjemah":"(Allah) tidak beranak dan tidak pula diperanakkan."},{"nomor":4,"arab":"وَلَمْ يَكُنْ لَّهٗ كُفُوًا اَحَدٌ ࣖ","terjemah":"Dan tidak ada sesuatu yang setara dengan Dia.”"}]}