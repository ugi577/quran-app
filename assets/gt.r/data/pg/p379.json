[{"s":27,"n":23,"t":"\u0625\u0650\u0646\u0651\u0650\u0649 \u0648\u064e\u062c\u064e\u062f\u062a\u0651\u064f \u0671\u0645\u0652\u0631\u064e\u0623\u064e\u0629\u064b\u06ed \u062a\u064e\u0645\u0652\u0644\u0650\u0643\u064f\u0647\u064f\u0645\u0652 \u0648\u064e\u0623\u064f\u0648\u062a\u0650\u064a\u064e\u062a\u0652 \u0645\u0650\u0646 \u0643\u064f\u0644\u0651\u0650 \u0634\u064e\u0649\u0652\u0621\u064d\u06e2 \u0648\u064e\u0644\u064e\u0647\u064e\u0627 \u0639\u064e\u0631\u0652\u0634\u064c \u0639\u064e\u0638\u0650\u064a\u0645\u064c\u06ed","j":19,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0646\u0651\u064e\u0645\u06e1\u0644\u0650"},{"s":27,"n":24,"t":"\u0648\u064e\u062c\u064e\u062f\u062a\u0651\u064f\u0647\u064e\u0627 \u0648\u064e\u0642\u064e\u0648\u0652\u0645\u064e\u0647\u064e\u0627 \u064a\u064e\u0633\u0652\u062c\u064f\u062f\u064f\u0648\u0646\u064e \u0644\u0650\u0644\u0634\u0651\u064e\u0645\u0652\u0633\u0650 \u0645\u0650\u0646 \u062f\u064f\u0648\u0646\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0648\u064e\u0632\u064e\u064a\u0651\u064e\u0646\u064e \u0644\u064e\u0647\u064f\u0645\u064f \u0671\u0644\u0634\u0651\u064e\u064a\u0652\u0637\u064e\u0670\u0646\u064f \u0623\u064e\u0639\u0652\u0645\u064e\u0670\u0644\u064e\u0647\u064f\u0645\u0652 \u0641\u064e\u0635\u064e\u062f\u0651\u064e\u0647\u064f\u0645\u0652 \u0639\u064e\u0646\u0650 \u0671\u0644\u0633\u0651\u064e\u0628\u0650\u064a\u0644\u0650 \u0641\u064e\u0647\u064f\u0645\u0652 \u0644\u064e\u0627 \u064a\u064e\u0647\u0652\u062a\u064e\u062f\u064f\u0648\u0646\u064e","j":19},{"s":27,"n":25,"t":"\u0623\u064e\u0644\u0651\u064e\u0627 \u064a\u064e\u0633\u0652\u062c\u064f\u062f\u064f\u0648\u0627\u06df \u0644\u0650\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0651\u064e\u0630\u0650\u0649 \u064a\u064f\u062e\u0652\u0631\u0650\u062c\u064f \u0671\u0644\u0652\u062e\u064e\u0628\u0652\u0621\u064e \u0641\u0650\u0649 \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u06