[{"s":30,"n":25,"t":"\u0648\u064e\u0645\u0650\u0646\u0652 \u0621\u064e\u0627\u064a\u064e\u0670\u062a\u0650\u0647\u0650\u06e6\u0653 \u0623\u064e\u0646 \u062a\u064e\u0642\u064f\u0648\u0645\u064e \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0627\u0653\u0621\u064f \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u064f \u0628\u0650\u0623\u064e\u0645\u0652\u0631\u0650\u0647\u0650\u06e6 \u06da \u062b\u064f\u0645\u0651\u064e \u0625\u0650\u0630\u064e\u0627 \u062f\u064e\u0639\u064e\u0627\u0643\u064f\u0645\u0652 \u062f\u064e\u0639\u0652\u0648\u064e\u0629\u064b\u06ed \u0645\u0651\u0650\u0646\u064e \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u0625\u0650\u0630\u064e\u0627\u0653 \u0623\u064e\u0646\u062a\u064f\u0645\u0652 \u062a\u064e\u062e\u0652\u0631\u064f\u062c\u064f\u0648\u0646\u064e","j":21,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0631\u0651\u064f\u0648\u0645\u0650"},{"s":30,"n":26,"t":"\u0648\u064e\u0644\u064e\u0647\u064f\u06e5 \u0645\u064e\u0646 \u0641\u0650\u0649 \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u06d6 \u0643\u064f\u0644\u0651\u064c\u06ed \u0644\u0651\u064e\u0647\u064f\u06e5 \u0642\u064e\u0670\u0646\u0650\u062a\u064f\u0648\u0646\u064e","j":21},{"s":30,"n":27,"t":"\u0648\u064e\u0647\u064f\u0648\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u0649 \u064a\u064e\u0628\u0652\u062f\u064e\u0624\u064f\u0627\u06df \u0671\u0644\u0652\u062e\u064e\u0644\u0652\u0642\u064e \u062b\u064f\u0645\u0651\u064e \u064a\u064f\u0639\u0650\u064a\u062f\u064f\u0647\u064f\u06e5 \u0648\u064e\u0647\u064f\u0648\u064e \u0623\u064e\u0647\u0652\u0648\u064e\u0646\u064f \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650 \u06da \u0648\u064e\u0644\u064e\u0647\u064f \u0671\u0644\u0652\u0645\u064e\u062b\u064e\u0644\u064f \u0671\u0644\u0652\u0623\u064e\u0639\u0652\u0644\u064e\u0649\u0670 \u0641\u0650\u0649 \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e