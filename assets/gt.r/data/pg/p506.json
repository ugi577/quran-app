[{"s":46,"n":29,"t":"\u0648\u064e\u0625\u0650\u0630\u0652 \u0635\u064e\u0631\u064e\u0641\u0652\u0646\u064e\u0627\u0653 \u0625\u0650\u0644\u064e\u064a\u0652\u0643\u064e \u0646\u064e\u0641\u064e\u0631\u064b\u06ed\u0627 \u0645\u0651\u0650\u0646\u064e \u0671\u0644\u0652\u062c\u0650\u0646\u0651\u0650 \u064a\u064e\u0633\u0652\u062a\u064e\u0645\u0650\u0639\u064f\u0648\u0646\u064e \u0671\u0644\u0652\u0642\u064f\u0631\u0652\u0621\u064e\u0627\u0646\u064e \u0641\u064e\u0644\u064e\u0645\u0651\u064e\u0627 \u062d\u064e\u0636\u064e\u0631\u064f\u0648\u0647\u064f \u0642\u064e\u0627\u0644\u064f\u0648\u0653\u0627\u06df \u0623\u064e\u0646\u0635\u0650\u062a\u064f\u0648\u0627\u06df \u06d6 \u0641\u064e\u0644\u064e\u0645\u0651\u064e\u0627 \u0642\u064f\u0636\u0650\u0649\u064e \u0648\u064e\u0644\u0651\u064e\u0648\u0652\u0627\u06df \u0625\u0650\u0644\u064e\u0649\u0670 \u0642\u064e\u0648\u0652\u0645\u0650\u0647\u0650\u0645 \u0645\u0651\u064f\u0646\u0630\u0650\u0631\u0650\u064a\u0646\u064e","j":26,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0623\u064e\u062d\u06e1\u0642\u064e\u0627\u0641\u0650"},{"s":46,"n":30,"t":"\u0642\u064e\u0627\u0644\u064f\u0648\u0627\u06df \u064a\u064e\u0670\u0642\u064e\u0648\u0652\u0645\u064e\u0646\u064e\u0627\u0653 \u0625\u0650\u0646\u0651\u064e\u0627 \u0633\u064e\u0645\u0650\u0639\u0652\u0646\u064e\u0627 \u0643\u0650\u062a\u064e\u0670\u0628\u064b\u0627 \u0623\u064f\u0646\u0632\u0650\u0644\u064e \u0645\u0650\u0646\u06e2 \u0628\u064e\u0639\u0652\u062f\u0650 \u0645\u064f\u0648\u0633\u064e\u0649\u0670 \u0645\u064f\u0635\u064e\u062f\u0651\u0650\u0642\u064b\u06ed\u0627 \u0644\u0651\u0650\u0645\u064e\u0627 \u0628\u064e\u064a\u0652\u0646\u064e \u064a\u064e\u062f\u064e\u064a\u0652\u0647\u0650 \u064a\u064e\u0647\u0652\u062f\u0650\u0649\u0653 \u0625\u0650\u0644\u064e\u0649 \u0671\u0644\u0652\u062d\u064e\u0642\u0651\u0650 \u0648\u064e\u0625\u0650\u0644\u064e\u0649\u0670 \u0637\u064e\u0631\u0650\u064a\u0642\u064d\u06e2 \u0645\u0651\u064f\u0633\u0652\u062a\u064e\u0642\u0650\u064a\u0645\u064d\u06e2","j":26},{"s":46,"n":31,"t":"\u064a\u064e\u0670\u0642\u064e\u0648\u0652\u0645\u064e\u0646\u064e\u0627\u0653 \u0623\u064e\u062c\u0650\u064a\u0628\u064f\u0648\u0627\u06df \u062f\u064e\u0627\u0639\u0650\u0649\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0648\u064e\u0621\u064e\u0627\u0645\u0650\u0646\u064f\u0648\u0627\u06df \u0628\u0650\u0647\u0650\u06e6 \u064a\u064e\u063a\u0652\u0641\u0650\u0631\u0652 \u0644\u064e\u0643\u064f\u0645 \u0645\u0651\u0650\u0646 \u0630\u064f\u0646\u064f\u0648\u0628\u0650\u0643\u064f\u0645\u0652 \u0648\u064e\u064a\u064f\u062c\u0650\u0631\u0652\u0643\u064f\u0645 \u0645\u0651\u0650\u0646\u0652 \u0639\u064e\u0630\u064e\u0627\u0628\u064d \u0623\u064e\u0644\u0650\u064a\u0645\u064d\u06e2","j":26},{"s":46,"n":32,"t":"\u0648\u064e\u0645\u064e\u0646 \u0644\u0651\u064e\u0627 \u064a\u064f\u062c\u0650\u0628\u0652 \u062f\u064e\u0627\u0639\u0650\u0649\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0641\u064e\u0644\u064e\u064a\u0652\u0633\u064e \u0628\u0650\u0645\u064f\u0639\u0652\u062c\u0650\u0632\u064d\u06e2 \u0641\u0650\u0649 \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u0648\u064e\u0644\u064e\u064a\u0652\u0633\u064e \u0644\u064e\u0647\u064f\u06e5 \u0645\u0650\u0646 \u062f\u064f\u0648\u0646\u0650\u0647\u0650\u06e6\u0653 \u0623\u064e\u0648\u0652\u0644\u0650\u064a\u064e\u0627\u0653\u0621\u064f \u06da \u0623\u064f\u0648\u06df\u0644\u064e\u0670\u0653\u0626\u0650\u0643\u064e \u0641\u0650\u0649 \u0636\u064e\u0644\u064e\u0670\u0644\u064d\u06e2 \u0645\u0651\u064f\u0628\u0650\u064a\u0646\u064d","j":26},{"s":46,"n":33,"t":"\u0623\u064e\u0648\u064e\u0644\u064e\u0645\u0652 \u064a\u064e\u0631\u064e\u0648\u0652\u0627\u06df \u0623\u064e\u0646\u0651\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u0649 \u062e\u064e\u0644\u064e\u0642\u064e \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u064e \u0648\u064e\u0644\u064e\u0645\u0652 \u064a\u064e\u0639\u0652\u0649\u064e \u0628\u0650\u062e\u064e\u0644\u0652\u0642\u0650\u0647\u0650\u0646\u0651\u064e \u0628\u0650\u0642\u064e\u0670\u062f\u0650\u0631\u064d \u0639\u064e\u0644\u064e\u0649\u0670\u0653 \u0623\u064e\u0646 \u064a\u064f\u062d\u0652\u06e6\u0650\u0649\u064e \u0671\u0644\u0652\u0645\u064e\u0648\u0652\u062a\u064e\u0649\u0670 \u06da \u0628\u064e\u0644\u064e\u0649\u0670\u0653 \u0625\u0650\u0646\u0651\u064e\u0647\u064f\u06e5 \u0639\u064e\u0644\u064e\u0649\u0670 \u0643\u064f\u0644\u0651\u0650 \u0634\u064e\u0649\u0652\u0621\u064d\u06e2 \u0642\u064e\u062f\u0650\u064a\u0631\u064c\u06ed","j":26},{"s":46,"n":34,"t":"\u0648\u064e\u064a\u064e\u0648\u0652\u0645\u064e \u064a\u064f\u0639\u0652\u0631\u064e\u0636\u064f \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0643\u064e\u0641\u064e\u0631\u064f\u0648\u0627\u06df \u0639\u064e\u0644\u064e\u0649 \u0671\u0644\u0646\u0651\u064e\u0627\u0631\u0650 \u0623\u064e\u0644\u064e\u064a\u0652\u0633\u064e \u0647\u064e\u0670\u0630\u064e\u0627 \u0628\u0650\u0671\u0644\u0652\u062d\u064e\u0642\u0651\u0650 \u06d6 \u0642\u064e\u0627\u0644\u064f\u0648\u0627\u06df \u0628\u064e\u0644\u064e\u0649\u0670 \u0648\u064e\u0631\u064e\u0628\u0651\u0650\u0646\u064e\u0627 \u06da \u0642\u064e\u0627\u0644\u064e \u0641\u064e\u0630\u064f\u0648\u0642\u064f\u0648\u0627\u06df \u0671\u0644\u0652\u0639\u064e\u0630\u064e\u0627\u0628\u064e \u0628\u0650\u0645\u064e\u0627 \u0643\u064f\u0646\u062a\u064f\u0645\u0652 \u062a\u064e\u0643\u0652\u0641\u064f\u0631\u064f\u0648\u0646\u064e","j":26},{"s":46,"n":35,"t":"\u0641\u064e\u0671\u0635\u0652\u0628\u0650\u0631\u0652 \u0643\u064e\u0645\u064e\u0627 \u0635\u064e\u0628\u064e\u0631\u064e \u0623\u064f\u0648\u06df\u0644\u064f\u0648\u0627\u06df \u0671\u0644\u0652\u0639\u064e\u0632\u0652\u0645\u0650 \u0645\u0650\u0646\u064e \u0671\u0644\u0631\u0651\u064f\u0633\u064f\u0644\u0650 \u0648\u064e\u0644\u064e\u0627 \u062a\u064e\u0633\u0652\u062a\u064e\u0639\u0652\u062c\u0650\u0644 \u0644\u0651\u064e\u0647\u064f\u0645\u0652 \u06da \u0643\u064e\u0623\u064e\u0646\u0651\u064e\u0647\u064f\u0645\u0652 \u064a\u064e\u0648\u0652\u0645\u064e \u064a\u064e\u0631\u064e\u0648\u0652\u0646\u064e \u0645\u064e\u0627 \u064a\u064f\u0648\u0639\u064e\u062f\u064f\u0648\u0646\u064e \u0644\u064e\u0645\u0652 \u064a\u064e\u0644\u0652\u0628\u064e\u062b\u064f\u0648\u0653\u0627\u06df \u0625\u0650\u0644\u0651\u064e\u0627 \u0633\u064e\u0627\u0639\u064e\u0629\u064b\u06ed \u0645\u0651\u0650\u0646 \u0646\u0651\u064e\u0647\u064e\u0627\u0631\u064d\u06ed \u06da \u0628\u064e\u0644\u064e\u0670\u063a\u064c\u06ed \u06da \u0641\u064e\u0647\u064e\u0644\u0652 \u064a\u064f\u0647\u0652\u0644\u064e\u0643\u064f \u0625\u0650\u0644\u0651\u064e\u0627 \u0671\u0644\u0652\u0642\u064e\u0648\u0652\u0645\u064f \u0671\u0644\u0652\u0641\u064e\u0670\u0633\u0650\u0642\u064f\u0648\u0646\u064e","j":26}]