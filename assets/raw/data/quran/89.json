{"n":89,"na":"الفجر","nl":"Al-Fajr","tt":"Mekah","ja":30,"ay":[{"n":1,"a":"وَالْفَجْرِۙ"},{"n":2,"a":"وَلَيَالٍ عَشْرٍۙ"},{"n":3,"a":"وَّالشَّفْعِ وَالْوَتْرِۙ"},{"n":4,"a":"وَالَّيْلِ اِذَا يَسْرِۚ"},{"n":5,"a":"هَلْ فِيْ ذٰلِكَ قَسَمٌ لِّذِيْ حِجْرٍۗ"},{"n":6,"a":"اَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعَادٍۖ"},{"n":7,"a":"اِرَمَ ذَاتِ الْعِمَادِۖ"},{"n":8,"a":"الَّتِيْ لَمْ يُخْلَقْ مِثْلُهَا فِى الْبِلَادِۖ"},{"n":9,"a":"وَثَمُوْدَ الَّذِيْنَ جَابُوا الصَّخْرَ بِالْوَادِۖ"},{"n":10,"a":"وَفِرْعَوْنَ ذِى الْاَوْتَادِۖ"},{"n":11,"a":"الَّذِيْنَ طَغَوْا فِى الْبِلَادِۖ"},{"n":12,"a":"فَاَكْثَرُوْا فِيْهَا الْفَسَادَۖ"},{"n":13,"a":"فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍۖ"},{"n":14,"a":"اِنَّ رَبَّكَ لَبِالْمِرْصَادِۗ"},{"n":15,"a":"فَاَمَّا الْاِنْسَانُ اِذَا مَا ابْتَلٰىهُ رَبُّهٗ فَاَكْرَمَهٗ وَنَعَّمَهٗۙ فَيَقُوْلُ رَبِّيْٓ اَكْرَمَنِۗ"},{"n":16,"a":"وَاَمَّآ اِذَا مَا ابْتَلٰىهُ فَقَدَرَ عَلَيْهِ رِزْقَهٗ ەۙ فَيَقُوْلُ رَبِّيْٓ اَهَانَنِۚ"},{"n":17,"a":"كَلَّا بَلْ لَّا تُكْرِمُوْنَ الْيَتِيْمَۙ"},{"n":18,"a":"وَلَا تَحٰۤضُّوْنَ عَلٰى طَعَامِ الْمِسْكِيْنِۙ"},{"n":19,"a":"وَتَأْكُلُوْنَ التُّرَاثَ اَكْلًا لَّمًّاۙ"},{"n":20,"a":"وَّتُحِبُّوْنَ الْمَالَ حُبًّا جَمًّاۗ"},{"n":21,"a":"كَلَّآ اِذَا دُكَّتِ الْاَرْضُ دَكًّا دَكًّاۙ"},{"n":22,"a":"وَّجَآءَ رَبُّكَ وَالْمَلَكُ صَفًّا صَفًّاۚ"},{"n":23,"a":"وَجِايْۤءَ يَوْمَىِٕذٍۢ بِجَهَنَّمَۙ يَوْمَىِٕذٍ يَّتَذَكَّرُ الْاِنْسَانُ وَاَنّٰى لَهُ الذِّكْرٰىۗ"},{"n":24,"a":"يَقُوْلُ يٰلَيْتَنِيْ قَدَّمْتُ لِحَيَاتِيْۚ"},{"n":25,"a":"فَيَوْمَىِٕذٍ لَّا يُعَذِّبُ عَذَابَهٗٓ اَحَدٌ ۙ"},{"n":26,"a":"وَّلَا يُوْثِقُ وَثَاقَهٗٓ اَحَدٌ ۗ"},{"n":27,"a":"يٰٓاَيَّتُهَا النَّفْسُ الْمُطْمَىِٕنَّةُۙ"},{"n":28,"a":"ارْجِعِيْٓ اِلٰى رَبِّكِ رَاضِيَةً مَّرْضِيَّةً ۚ"},{"n":29,"a":"فَادْخُلِيْ فِيْ عِبٰدِيْۙ"},{"n":30,"a":"وَادْخُلِيْ جَنَّتِيْ ࣖࣖ"}]}