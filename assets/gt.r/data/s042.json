{"n":42,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0634\u0651\u064f\u0648\u0631\u064e\u0649\u0670","en":"Ash-Shura","ayat":[{"n":1,"t":"\u0628\u0650\u0633\u0652\u0645\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0652\u0645\u064e\u0670\u0646\u0650 \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u0650 \u062d\u0645\u0653","p":483,"j":25},{"n":2,"t":"\u0639\u0653\u0633\u0653\u0642\u0653","p":483,"j":25},{"n":3,"t":"\u0643\u064e\u0630\u064e\u0670\u0644\u0650\u0643\u064e \u064a\u064f\u0648\u062d\u0650\u0649\u0653 \u0625\u0650\u0644\u064e\u064a\u0652\u0643\u064e \u0648\u064e\u0625\u0650\u0644\u064e\u0649 \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0645\u0650\u0646 \u0642\u064e\u0628\u0652\u0644\u0650\u0643\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0671\u0644\u0652\u0639\u064e\u0632\u0650\u064a\u0632\u064f \u0671\u0644\u0652\u062d\u064e\u0643\u0650\u064a\u0645\u064f","p":483,"j":25},{"n":4,"t":"\u0644\u064e\u0647\u064f\u06e5 \u0645\u064e\u0627 \u0641\u0650\u0649 \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0645\u064e\u0627 \u0641\u0650\u0649 \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u06d6 \u0648\u064e\u0647\u064f\u0648\u064e \u0671\u0644\u0652\u0639\u064e\u0644\u0650\u0649\u0651\u064f \u0671\u0644\u0652\u0639\u064e\u0638\u0650\u064a\u0645\u064f","p":483,"j":25},{"n":5,"t":"\u062a\u064e\u0643\u064e\u0627\u062f\u064f \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u064f \u064a\u064e\u062a\u064e\u0641\u064e\u0637\u0651\u064e\u0631\u0652\u0646\u064e \u0645\u0650\u0646 \u0641\u064e\u0648\u0652\u0642\u0650\u0647\u0650\u0646\u0651\u064e \u06da \u0648\u064e\u0671\u0644\u0652\u0645\u064e\u0644\u064e\u0670\u0653\u0626\u0650\u0643\u064e\u0629\u064f \u064a\u064f\u0633\u064e\u0628\u0651\u0650\u062d\u064f\u0648\u0646\u064e \u0628\u0650\u062d\u064e\u0645\u0652\u062f\u0650 \u0631\u064e\u0628\u0651\u0650\u0647\u0650\u0645\u0652 \u0648\u064e\u064a\u064e\u0633\u0652\u062a\u064e\u063a\u0652\u0641\u0650\u0631\u064f\u0648\u0646\u064e \u0644\u0650\u0645\u064e\u0646 \u0641\u0650\u0649 \u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u06d7 \u0623\u064e\u0644\u064e\u0627\u0653 \u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u0647\u064f\u0648\u064e \u0671\u0644\u0652\u063a\u064e\u0641\u064f\u0648\u0631\u064f \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u064f","p":483,"j":25},{"n":6,"t":"\u0648\u064e\u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0671\u062a\u0651\u064e\u062e\u064e\u0630\u064f\u0648\u0627\u06df \u0645\u0650\u0646 \u062f\u064f\u0648\u0646\u0650\u0647\u0650\u06e6\u0653 \u0623\u064e\u0648\u0652\u0644\u0650\u064a\u064e\u0627\u0653\u0621\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u062d\u064e\u0641\u0650\u064a\u0638\u064c \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650\u0645\u0652 \u0648\u064e\u0645\u064e\u0627\u0653 \u0623\u064e\u0646\u062a\u064e \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650\u0645 \u0628\u0650\u0648\u064e\u0643\u0650\u064a\u0644\u064d\u06e2","p":483,"j":25},{"n":7,"t":"\u0648\u064e\u0643\u064e\u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0623\u064e\u0648\u0652\u062d\u064e\u064a\u0652\u0646\u064e\u0627\u0653 \u0625\u0650\u0644\u064e\u064a\u0652\u0643\u064e \u0642\u064f\u0631\u0652\u0621\u064e\u0627\u0646\u064b\u0627 \u0639\u064e\u0631\u064e\u0628\u0650\u064a\u0651\u064b\u06ed\u0627 \u0644\u0651\u0650\u062a\u064f\u0646\u0630\u0650\u0631\u064e \u0623\u064f\u0645\u0651\u064e \u0671\u0644\u0652\u0642\u064f\u0631\u064e\u0649\u0670 \u0648\u064e\u0645\u064e\u0646\u0652 \u062d\u064e\u0648\u0652\u0644\u064e\u0647\u064e\u0627 \u0648\u064e\u062a\u064f\u0646\u0630\u0650\u0631\u064e \u064a\u064e\u0648\u0652\u0645\u064e \u0671\u0644\u0652\u062c\u064e\u0645\u0652\u0639\u0650 \u0644\u064e\u0627 \u0631\u064e\u064a\u0652\u0628\u064e \u0641\u0650\u064a\u0647\u0650 \u06da \u0641\u064e\u0631\u0650\u064a\u0642\u064c\u06ed \u0641\u0650\u0649 \u0671\u0644\u0652\u062c\u064e\u0646\u0651\u064e\u0629\u0650 \u0648\u064e\u0641\u064e\u0631\u0650\u064a\u0642\u064c\u06ed \u0641\u0650\u0649 \u0671\u0644\u0633\u0651\u064e\u0639\u0650\u064a\u0631\u0650","p":483,"j":25},{"n":8,"t":"\u0648\u064e\u0644\u064e\u0648\u0652 \u0634\u064e\u0627\u0653\u0621\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0644\u064e\u062c\u064e\u0639\u064e\u0644\u064e\u0647\u064f\u0645\u0652 \u0623\u064f\u0645\u0651\u064e\u0629\u064b\u06ed \u0648\u064e\u0670\u062d\u0650\u062f\u064e\u0629\u064b\u06ed \u0648\u064e\u0644\u064e\u0670\u0643\u0650\u0646 \u064a\u064f\u062f\u0652\u062e\u0650\u0644\u064f \u0645\u064e\u0646 \u064a\u064e\u0634\u064e\u0627\u0653\u0621\u064f \u0641\u0650\u0649 \u0631\u064e\u062d\u0652\u0645\u064e\u062a\u0650\u0647\u0650\u06e6 \u06da \u0648\u064e\u0671\u0644\u0638\u0651\u064e\u0670\u0644\u0650\u0645\u064f\u0648\u0646\u064e \u0645\u064e\u0627 \u0644\u064e\u0647\u064f\u0645 \u0645\u0651\u0650\u0646 \u0648\u064e\u0644\u0650\u0649\u0651\u064d\u06e2 \u0648\u064e\u0644\u064e\u0627 \u0646\u064e\u0635\u0650\u064a\u0631\u064d","p":483,"j":25},{"n":9,"t":"\u0623\u064e\u0645\u0650 \u0671\u062a\u0651\u064e\u062e\u064e\u0630\u064f\u0648\u0627\u06df \u0645\u0650\u0646 \u062f\u064f\u0648\u0646\u0650\u0647\u0650\u06e6\u0653 \u0623\u064e\u0648\u0652\u0644\u0650\u064a\u064e\u0627\u0653\u0621\u064e \u06d6 \u0641\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0647\u064f\u0648\u064e \u0671\u0644\u0652\u0648\u064e\u0644\u0650\u0649\u0651\u064f \u0648\u064e\u0647\u064f\u0648\u064e \u064a\u064f\u062d\u0652\u0649\u0650 \u0671\u0644\u0652\u0645\u064e\u0648\u0652\u062a\u064e\u0649\u0670 \u0648\u064e\u0647\u064f\u0648\u064e \u0639\u064e\u0644\u064e\u0649\u0670 \u0643\u064f\u0644\u0651\u0650 \u0634\u064e\u0649\u0652\u0621\u064d\u06e2 \u0642\u064e\u062f\u0650\u064a\u0631\u064c\u06ed","p":483,"j":25},{"n":10,"t":"\u0648\u064e\u0645\u064e\u0627 \u0671\u062e\u0652\u062a\u064e\u0644\u064e\u0641\u0652\u062a\u064f\u0645\u0652 \u0641\u0650\u064a\u0647\u0650 \u0645\u0650\u0646 \u0634\u064e\u0649\u0652\u0621\u064d\u06e2 \u0641\u064e\u062d\u064f\u0643\u0652\u0645\u064f\u0647\u064f\u06e5\u0653 \u0625\u0650\u0644\u064e\u0649 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u06da \u0630\u064e\u0670\u0644\u0650\u0643\u064f\u0645\u064f \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0631\u064e\u0628\u0651\u0650\u0649 \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650 \u062a\u064e\u0648\u064e\u0643\u0651\u064e\u0644\u0652\u062a\u064f \u0648\u064e\u0625\u0650\u0644\u064e\u064a\u0652\u0647\u0650 \u0623\u064f\u0646\u0650\u064a\u0628\u064f","p":483,"j":25},{"n":11,"t":"\u0641\u064e\u0627\u0637\u0650\u0631\u064f \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u06da \u062c\u064e\u0639\u064e\u0644\u064e \u0644\u064e\u0643\u064f\u0645 \u0645\u0651\u0650\u0646\u0652 \u0623\u064e\u0646\u0641\u064f\u0633\u0650\u0643\u064f\u0645\u0652 \u0623\u064e\u0632\u0652\u0648\u064e\u0670\u062c\u064b\u06ed\u0627 \u0648\u064e\u0645\u0650\u0646\u064e \u0671\u0644\u0652\u0623\u064e\u0646\u0652\u0639\u064e\u0670\u0645\u0650 \u0623\u064e\u0632\u0652\u0648\u064e\u0670\u062c\u064b\u06ed\u0627 \u06d6 \u064a\u064e\u0630\u0652\u0631\u064e\u0624\u064f\u0643\u064f\u0645\u0652 \u0641\u0650\u064a\u0647\u0650 \u06da \u0644\u064e\u064a\u0652\u0633\u064e \u0643\u064e\u0645\u0650\u062b\u0652\u0644\u0650\u0647\u0650\u06e6 \u0634\u064e\u0649\u0652\u0621\u064c\u06ed \u06d6 \u0648\u064e\u0647\u064f\u0648\u064e \u0671\u0644\u0633\u0651\u064e\u0645\u0650\u064a\u0639\u064f \u0671\u0644\u0652\u0628\u064e\u0635\u0650\u064a\u0631\u064f","p":484,"j":25},{"n":12,"t":"\u0644\u064e\u0647\u064f\u06e5 \u0645\u064e\u0642\u064e\u0627\u0644\u0650\u064a\u062f\u064f \u0671\u0644\u0633\u0651\u064e\u0645\u064e\u0670\u0648\u064e\u0670\u062a\u0650 \u0648\u064e\u0671\u0644\u0652\u0623\u064e\u0631\u0652\u0636\u0650 \u06d6 \u064a\u064e\u0628\u0652\u0633\u064f\u0637\u064f \u0671\u0644\u0631\u0651\u0650\u0632\u0652\u0642\u064e \u0644\u0650\u0645\u064e\u0646 \u064a\u064e\u0634\u064e\u0627\u0653\u0621\u064f \u0648\u064e\u064a\u064e\u0642\u0652\u062f\u0650\u0631\u064f \u06da \u0625\u0650\u0646\u0651\u064e\u0647\u064f\u06e5 \u0628\u0650\u0643\u064f\u0644\u0651\u0650 \u0634\u064e\u0649\u0652\u0621\u064d \u0639\u064e\u0644\u0650\u064a\u0645\u064c\u06ed","p":484,"j":25},{"n":13,"t":"\u06de \u0634\u064e\u0631\u064e\u0639\u064e \u0644\u064e\u0643\u064f\u0645 \u0645\u0651\u0650\u0646\u064e \u0671\u0644\u062f\u0651\u0650\u064a\u0646\u0650 \u0645\u064e\u0627 \u0648\u064e\u0635\u0651\u064e\u0649\u0670 \u0628\u0650\u0647\u0650\u06e6 \u0646\u064f\u0648\u062d\u064b\u06ed\u0627 \u0648\u064e\u0671\u0644\u0651\u064e\u0630\u0650\u0649\u0653 \u0623\u064e\u0648\u0652\u062d\u064e\u064a\u0652\u0646\u064e\u0627\u0653 \u0625\u0650\u0644\u064e\u064a\u0652\u0643\u064e \u0648\u064e\u0645\u064e\u0627 \u0648\u064e\u0635\u0651\u064e\u064a\u0652\u0646\u064e\u0627 \u0628\u0650\u0647\u0650\u06e6\u0653 \u0625\u0650\u0628\u0652\u0631\u064e\u0670\u0647\u0650\u064a\u0645\u064e \u0648\u064e\u0645\u064f\u0648\u0633\u064e\u0649\u0670 \u0648\u064e\u0639\u0650\u064a\u0633\u064e\u0649\u0670\u0653 \u06d6 \u0623\u064e\u0646\u0652 \u0623\u064e\u0642\u0650\u064a\u0645\u064f\u0648\u0627\u06df \u0671\u0644\u062f\u0651\u0650\u064a\u0646\u064e \u0648\u064e\u0644\u064e\u0627 \u062a\u064e\u062a\u064e\u0641\u064e\u0631\u0651\u064e\u0642\u064f\u0648\u0627\u06df \u0641\u0650\u064a\u0647\u0650 \u06da \u0643\u064e\u0628\u064f\u0631\u064e \u0639\u064e\u0644\u064e\u0649 \u0671\u0644\u0652\u0645\u064f\u0634\u0652\u0631\u0650\u0643\u0650\u064a\u0646\u064e \u0645\u064e\u0627 \u062a\u064e\u062f\u0652\u0639\u064f\u0648\u0647\u064f\u0645\u0652 \u0625\u0650\u0644\u064e\u064a\u0652\u0647\u0650 \u06da \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u064a\u064e\u062c\u0652\u062a\u064e\u0628\u0650\u0649\u0653 \u0625\u0650\u0644\u064e\u064a\u0652\u0647\u0650 \u0645\u064e\u0646 \u064a\u064e\u0634\u064e\u0627\u0653\u0621\u064f \u0648\u064e\u064a\u064e\u0647\u0652\u062f\u0650\u0649\u0653 \u0625\u0650\u0644\u064e\u064a\u0652\u0647\u0650 \u0645\u064e\u0646 \u064a\u064f\u0646\u0650\u064a\u0628\u064f","p":484,"j":25},{"n":14,"t":"\u0648\u064e\u0645\u064e\u0627 \u062a\u064e\u0641\u064e\u0631\u0651\u064e\u0642\u064f\u0648\u0653\u0627\u06df \u0625\u0650\u0644\u0651\u064e\u0627 \u0645\u0650\u0646\u06e2 \u0628\u064e\u0639\u0652\u062f\u0650 \u0645\u064e\u0627 \u062c\u064e\u0627\u0653\u0621\u064e\u0647\u064f\u0645\u064f \u0671\u0644\u0652\u0639\u0650\u0644\u0652\u0645\u064f \u0628\u064e\u063a\u0652\u064a\u064b\u06e2\u0627 \u0628\u064e\u064a\u0652\u0646\u064e\u0647\u064f\u0645\u0652 \u06da \u0648\u064e\u0644\u064e\u0648\u0652\u0644\u064e\u0627 \u0643\u064e\u0644\u0650\u0645\u064e\u0629\u064c\u06ed \u0633\u064e\u0628\u064e\u0642\u064e\u062a\u0652 \u0645\u0650\u0646 \u0631\u0651\u064e\u0628\u0651\u0650\u0643\u064e \u0625\u0650\u0644\u064e\u0649\u0670\u0653 \u0623\u064e\u062c\u064e\u0644\u064d\u06e2 \u0645\u0651\u064f\u0633\u064e\u0645\u0651\u064b\u06ed\u0649 \u0644\u0651\u064e\u0642\u064f\u0636\u0650\u0649\u064e \u0628\u064e\u064a\u0652\u0646\u064e\u0647\u064f\u0645\u0652 \u06da \u0648\u064e\u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0623\u064f\u0648\u0631\u0650\u062b\u064f\u0648\u0627\u06df \u0671\u0644\u0652\u0643\u0650\u062a\u064e\u0670\u0628\u064e \u0645\u0650\u0646\u06e2 \u0628\u064e\u0639\u0652\u062f\u0650\u0647\u0650\u0645\u0652 \u0644\u064e\u0641\u0650\u0649 \u0634\u064e\u0643\u0651\u064d\u06e2 \u0645\u0651\u0650\u0646\u0652\u0647\u064f \u0645\u064f\u0631\u0650\u064a\u0628\u064d\u06e2","p":484,"j":25},{"n":15,"t":"\u0641\u064e\u0644\u0650\u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0641\u064e\u0671\u062f\u0652\u0639\u064f \u06d6 \u0648\u064e\u0671\u0633\u0652\u062a\u064e\u0642\u0650\u0645\u0652 \u0643\u064e\u0645\u064e\u0627\u0653 \u0623\u064f\u0645\u0650\u0631\u0652\u062a\u064e \u06d6 \u0648\u064e\u0644\u064e\u0627 \u062a\u064e\u062a\u0651\u064e\u0628\u0650\u0639\u0652 \u0623\u064e\u0647\u0652\u0648\u064e\u0627\u0653\u0621\u064e\u0647\u064f\u0645\u0652 \u06d6 \u0648\u064e\u0642\u064f\u0644\u0652 \u0621\u064e\u0627\u0645\u064e\u0646\u062a\u064f \u0628\u0650\u0645\u064e\u0627\u0653 \u0623\u064e\u0646\u0632\u064e\u0644\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0645\u0650\u0646 \u0643\u0650\u062a\u064e\u0670\u0628\u064d\u06e2 \u06d6 \u0648\u064e\u0623\u064f\u0645\u0650\u0631\u0652\u062a\u064f \u0644\u0650\u0623\u064e\u0639\u0652\u062f\u0650\u0644\u064e \u0628\u064e\u064a\u0652\u0646\u064e\u0643\u064f\u0645\u064f \u06d6 \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0631\u064e\u0628\u0651\u064f\u0646\u064e\u0627 \u0648\u064e\u0631\u064e\u0628\u0651\u064f\u0643\u064f\u0645\u0652 \u06d6 \u0644\u064e\u0646\u064e\u0627\u0653 \u0623\u064e\u0639\u0652\u0645\u064e\u0670\u0644\u064f\u0646\u064e\u0627 \u0648\u064e\u0644\u064e\u0643\u064f\u0645\u0652 \u0623\u064e\u0639\u0652\u0645\u064e\u0670\u0644\u064f\u0643\u064f\u0645\u0652 \u06d6 \u0644\u064e\u0627 \u062d\u064f\u062c\u0651\u064e\u0629\u064e \u0628\u064e\u064a\u0652\u0646\u064e\u0646\u064e\u0627 \u0648\u064e\u0628\u064e\u064a\u0652\u0646\u064e\u0643\u064f\u0645\u064f \u06d6 \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u064a\u064e\u062c\u0652\u0645\u064e\u0639\u064f \u0628\u064e\u064a\u0652\u0646\u064e\u0646\u064e\u0627 \u06d6 \u0648\u064e\u0625\u0650\u0644\u064e\u064a\u0652\u0647\u0650 \u0671\u0644\u0652\u0645\u064e\u0635\u0650\u064a\u0631\u064f","p":484,"j":25},{"n":16,"t":"\u0648\u064e\u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u064a\u064f\u062d\u064e\u0627\u0653\u062c\u0651\u064f\u0648\u0646\u064e \u0641\u0650\u0649 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0645\u0650\u0646\u06e2 \u0628\u064e\u0639\u0652\u062f\u0650 \u0645\u064e\u0627 \u0671\u0633\u0652\u062a\u064f\u062c\u0650\u064a\u0628\u064e \u0644\u064e\u0647\u064f\u06e5 \u062d\u064f\u062c\u0651\u064e\u062a\u064f\u0647\u064f\u0645\u0652 \u062f\u064e\u0627\u062d\u0650\u0636\u064e\u0629\u064c \u0639\u0650\u0646\u062f\u064e \u0631\u064e\u0628\u0651\u0650\u0647\u0650\u0645\u0652 \u0648\u064e\u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650\u0645\u0652 \u063a\u064e\u0636\u064e\u0628\u064c\u06ed \u0648\u064e\u0644\u064e\u0647\u064f\u0645\u0652 \u0639\u064e\u0630\u064e\u0627\u0628\u064c\u06ed \u0634\u064e\u062f\u0650\u064a\u062f\u064c","p":485,"j":25},{"n":17,"t":"\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0671\u0644\u0651\u064e\u0630\u0650\u0649\u0653 \u0623\u064e\u0646\u0632\u064e\u0644\u064e \u0671\u0644\u0652\u0643\u0650\u062a\u064e\u0670\u0628\u064e \u0628\u0650\u0671\u0644\u0652\u062d\u064e\u0642\u0651\u0650 \u0648\u064e\u0671\u0644\u0652\u0645\u0650\u064a\u0632\u064e\u0627\u0646\u064e \u06d7 \u0648\u064e\u0645\u064e\u0627 \u064a\u064f\u062f\u0652\u0631\u0650\u064a\u0643\u064e \u0644\u064e\u0639\u064e\u0644\u0651\u064e \u0671\u0644\u0633\u0651\u064e\u0627\u0639\u064e\u0629\u064e \u0642\u064e\u0631\u0650\u064a\u0628\u064c\u06ed","p":485,"j":25},{"n":18,"t":"\u064a\u064e\u0633\u0652\u062a\u064e\u0639\u0652\u062c\u0650\u0644\u064f \u0628\u0650\u0647\u064e\u0627 \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0644\u064e\u0627 \u064a\u064f\u0624\u0652\u0645\u0650\u0646\u064f\u0648\u0646\u064e \u0628\u0650\u0647\u064e\u0627 \u06d6 \u0648\u064e\u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0621\u064e\u0627\u0645\u064e\u0646\u064f\u0648\u0627\u06df \u0645\u064f\u0634\u0652\u0641\u0650\u0642\u064f\u0648\u0646\u064e \u0645\u0650\u0646\u0652\u0647\u064e\u0627 \u0648\u064e\u064a\u064e\u0639\u0652\u0644\u064e\u0645\u064f\u0648\u0646\u064e \u0623\u064e\u0646\u0651\u064e\u0647\u064e\u0627 \u0671\u0644\u0652\u062d\u064e\u0642\u0651\u064f \u06d7 \u0623\u064e\u0644\u064e\u0627\u0653 \u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u064a\u064f\u0645\u064e\u0627\u0631\u064f\u0648\u0646\u064e \u0641\u0650\u0649 \u0671\u0644\u0633\u0651\u064e\u0627\u0639\u064e\u0629\u0650 \u0644\u064e\u0641\u0650\u0649 \u0636\u064e\u0644\u064e\u0670\u0644\u064d\u06ed \u0628\u064e\u0639\u0650\u064a\u062f\u064d","p":485,"j":25},{"n":19,"t":"\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0644\u064e\u0637\u0650\u064a\u0641\u064c\u06e2 \u0628\u0650\u0639\u0650\u0628\u064e\u0627\u062f\u0650\u0647\u0650\u06e6 \u064a\u064e\u0631\u0652\u0632\u064f\u0642\u064f \u0645\u064e\u0646 \u064a\u064e\u0634\u064e\u0627\u0653\u0621\u064f \u06d6 \u0648\u064e\u0647\u064f\u0648\u064e \u0671\u0644\u0652\u0642\u064e\u0648\u0650\u0649\u0651\u064f \u0671\u0644\u0652\u0639\u064e\u0632\u0650\u064a\u0632\u064f","p":485,"j":25},{"n":20,"t":"\u0645\u064e\u0646 \u0643\u064e\u0627\u0646\u064e \u064a\u064f\u0631\u0650\u064a\u062f\u064f \u062d\u064e\u0631\u0652\u062b\u064e \u0671\u0644\u0652\u0621\u064e\u0627\u062e\u0650\u0631\u064e\u0629\u0650 \u0646\u064e\u0632\u0650\u062f\u0652 \u0644\u064e\u0647\u064f\u06e5 \u0641\u0650\u0649 \u062d\u064e\u0631\u0652\u062b\u0650\u0647\u0650\u06e6 \u06d6 \u0648\u064e\u0645\u064e\u0646 \u0643\u064e\u0627\u0646\u064e \u064a\u064f\u0631\u0650\u064a\u062f\u064f \u062d\u064e\u0631\u0652\u062b\u064e \u0671\u0644\u062f\u0651\u064f\u0646\u0652\u064a\u064e\u0627 \u0646\u064f\u0624\u0652\u062a\u0650\u0647\u0650\u06e6 \u0645\u0650\u0646\u0652\u0647\u064e\u0627 \u0648\u064e\u0645\u064e\u0627 \u0644\u064e\u0647\u064f\u06e5 \u0641\u0650\u0649 \u0671\u0644\u0652\u0621\u064e\u0627\u062e\u0650\u0631\u064e\u0629\u0650 \u0645\u0650\u0646 \u0646\u0651\u064e\u0635\u0650\u064a\u0628\u064d","p":485,"j":25},{"n":21,"t":"\u0623\u064e\u0645\u0652 \u0644\u064e\u0647\u064f\u0645\u0652 \u0634\u064f\u0631\u064e\u0643\u064e\u0670\u0653\u0624\u064f\u0627\u06df \u0634\u064e\u0631\u064e\u0639\u064f\u0648\u0627\u06df \u0644\u064e\u0647\u064f\u0645 \u0645\u0651\u0650\u0646\u064e \u0671\u0644\u062f\u0651\u0650\u064a\u0646\u0650 \u0645\u064e\u0627 \u0644\u064e\u0645\u0652 \u064a\u064e\u0623\u0652\u0630\u064e\u0646\u06e2 \u0628\u0650\u0647\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u06da \u0648\u064e\u0644\u064e\u0648\u0652\u0644\u064e\u0627 \u0643\u064e\u0644\u0650\u0645\u064e\u0629\u064f \u0671\u0644\u0652\u0641\u064e\u0635\u0652\u0644\u0650 \u0644\u064e\u0642\u064f\u0636\u0650\u0649\u064e \u0628\u064e\u064a\u0652\u0646\u064e\u0647\u064f\u0645\u0652 \u06d7 \u0648\u064e\u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0638\u0651\u064e\u0670\u0644\u0650\u0645\u0650\u064a\u0646\u064e \u0644\u064e\u0647\u064f\u0645\u0652 \u0639\u064e\u0630\u064e\u0627\u0628\u064c \u0623\u064e\u0644\u0650\u064a\u0645\u064c\u06ed","p":485,"j":25},{"n":22,"t":"\u062a\u064e\u0631\u064e\u0649 \u0671\u0644\u0638\u0651\u064e\u0670\u0644\u0650\u0645\u0650\u064a\u0646\u064e \u0645\u064f\u0634\u0652\u0641\u0650\u0642\u0650\u064a\u0646\u064e \u0645\u0650\u0645\u0651\u064e\u0627 \u0643\u064e\u0633\u064e\u0628\u064f\u0648\u0627\u06df \u0648\u064e\u0647\u064f\u0648\u064e \u0648\u064e\u0627\u0642\u0650\u0639\u064c\u06e2 \u0628\u0650\u0647\u0650\u0645\u0652 \u06d7 \u0648\u064e\u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0621\u064e\u0627\u0645\u064e\u0646\u064f\u0648\u0627\u06df \u0648\u064e\u0639\u064e\u0645\u0650\u0644\u064f\u0648\u0627\u06df \u0671\u0644\u0635\u0651\u064e\u0670\u0644\u0650\u062d\u064e\u0670\u062a\u0650 \u0641\u0650\u0649 \u0631\u064e\u0648\u0652\u0636\u064e\u0627\u062a\u0650 \u0671\u0644\u0652\u062c\u064e\u0646\u0651\u064e\u0627\u062a\u0650 \u06d6 \u0644\u064e\u0647\u064f\u0645 \u0645\u0651\u064e\u0627 \u064a\u064e\u0634\u064e\u0627\u0653\u0621\u064f\u0648\u0646\u064e \u0639\u0650\u0646\u062f\u064e \u0631\u064e\u0628\u0651\u0650\u0647\u0650\u0645\u0652 \u06da \u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0647\u064f\u0648\u064e \u0671\u0644\u0652\u0641\u064e\u0636\u0652\u0644\u064f \u0671\u0644\u0652\u0643\u064e\u0628\u0650\u064a\u0631\u064f","p":485,"j":25},{"n":23,"t":"\u0630\u064e\u0670\u0644\u0650\u0643\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u0649 \u064a\u064f\u0628\u064e\u0634\u0651\u0650\u0631\u064f \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0639\u0650\u0628\u064e\u0627\u062f\u064e\u0647\u0