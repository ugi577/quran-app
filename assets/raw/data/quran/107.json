{"nomor":107,"nama":"الماعون","namaLatin":"Al-Ma'un","tempatTurun":"Mekah","jumlahAyat":7,"ayat":[{"nomor":1,"arab":"اَرَءَيْتَ الَّذِيْ يُكَذِّبُ بِالدِّيْنِۗ","terjemah":"Tahukah kamu (orang) yang mendustakan agama?"},{"nomor":2,"arab":"فَذٰلِكَ الَّذِيْ يَدُعُّ الْيَتِيْمَۙ","terjemah":"Maka itulah orang yang menghardik anak yatim,"},{"nomor":3,"arab":"وَلَا يَحُضُّ عَلٰى طَعَامِ الْمِسْكِيْنِۗ","terjemah":"dan tidak mendorong memberi makan orang miskin."},{"nomor":4,"arab":"فَوَيْلٌ لِّلْمُصَلِّيْنَۙ","terjemah":"Maka celakalah orang yang salat,"},{"nomor":5,"arab":"الَّذِيْنَ هُمْ عَنْ صَلَاتِهِمْ سَاهُوْنَۙ","terjemah":"(yaitu) orang-orang yang lalai terhadap salatnya,"},{"nomor":6,"arab":"الَّذِيْنَ هُمْ يُرَاۤءُوْنَۙ","terjemah":"yang berbuat ria,"},{"nomor":7,"arab":"وَيَمْنَعُوْنَ الْمَاعُوْنَ ࣖ","terjemah":"dan enggan (memberikan) bantuan."}]}