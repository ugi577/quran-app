{"n":93,"na":"الضحى","nl":"Ad-Duha","tt":"Mekah","ja":11,"ay":[{"n":1,"a":"وَالضُّحٰىۙ"},{"n":2,"a":"وَالَّيْلِ اِذَا سَجٰىۙ"},{"n":3,"a":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلٰىۗ"},{"n":4,"a":"وَلَلْاٰخِرَةُ خَيْرٌ لَّكَ مِنَ الْاُوْلٰىۗ"},{"n":5,"a":"وَلَسَوْفَ يُعْطِيْكَ رَبُّكَ فَتَرْضٰىۗ"},{"n":6,"a":"اَلَمْ يَجِدْكَ يَتِيْمًا فَاٰوٰىۖ"},{"n":7,"a":"وَوَجَدَكَ ضَاۤلًّا فَهَدٰىۖ"},{"n":8,"a":"وَوَجَدَكَ عَاۤىِٕلًا فَاَغْنٰىۗ"},{"n":9,"a":"فَاَمَّا الْيَتِيْمَ فَلَا تَقْهَرْۗ"},{"n":10,"a":"وَاَمَّا السَّاۤىِٕلَ فَلَا تَنْهَرْ"},{"n":11,"a":"وَاَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ ࣖ"}]}