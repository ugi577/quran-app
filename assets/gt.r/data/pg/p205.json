[{"s":9,"n":112,"t":"\u0671\u0644\u062a\u0651\u064e\u0670\u0653\u0626\u0650\u0628\u064f\u0648\u0646\u064e \u0671\u0644\u0652\u0639\u064e\u0670\u0628\u0650\u062f\u064f\u0648\u0646\u064e \u0671\u0644\u0652\u062d\u064e\u0670\u0645\u0650\u062f\u064f\u0648\u0646\u064e \u0671\u0644\u0633\u0651\u064e\u0670\u0653\u0626\u0650\u062d\u064f\u0648\u0646\u064e \u0671\u0644\u0631\u0651\u064e\u0670\u0643\u0650\u0639\u064f\u0648\u0646\u064e \u0671\u0644\u0633\u0651\u064e\u0670\u062c\u0650\u062f\u064f\u0648\u0646\u064e \u0671\u0644\u0652\u0621\u064e\u0627\u0645\u0650\u0631\u064f\u0648\u0646\u064e \u0628\u0650\u0671\u0644\u0652\u0645\u064e\u0639\u0652\u0631\u064f\u0648\u0641\u0650 \u0648\u064e\u0671\u0644\u0646\u0651\u064e\u0627\u0647\u064f\u0648\u0646\u064e \u0639\u064e\u0646\u0650 \u0671\u0644\u0652\u0645\u064f\u0646\u0643\u064e\u0631\u0650 \u0648\u064e\u0671\u0644\u0652\u062d\u064e\u0670\u0641\u0650\u0638\u064f\u0648\u0646\u064e \u0644\u0650\u062d\u064f\u062f\u064f\u0648\u062f\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u06d7 \u0648\u064e\u0628\u064e\u0634\u0651\u0650\u0631\u0650 \u0671\u0644\u0652\u0645\u064f\u0624\u0652\u0645\u0650\u0646\u0650\u064a\u0646\u064e","j":11,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u062a\u0651\u064e\u0648\u06e1\u0628\u064e\u0629\u0650"},{"s":9,"n":113,"t":"\u0645\u064e\u0627 \u0643\u064e\u0627\u0646\u064e \u0644\u0650\u0644\u0646\u0651\u064e\u0628\u0650\u0649\u0651\u0650 \u0648\u064e\u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0621\u064e\u0627\u0645\u064e\u0646\u064f\u0648\u0653\u0627\u06df \u0623\u064e\u0646 \u064a\u064e\u0633\u0652\u062a\u064e\u063a\u0652\u0641\u0650\u0631\u064f\u0648\u0627\u06df \u0644\u0650\u0644\u0652\u0645\u064f\u0634\u0652\u0631\u0650\u0643\u0650\u064a\u0646\u064e \u0648\u064e\u0644\u064e\u0648\u0652 \u0643\u064e\u0627\u0646\u064f\u0648\u0653\u0627\u06df \u0623\u064f\u0648\u06df\u0644\u0650\u0649 \u0642\u064f\u0631\u0652\u0628\u064e\u0649\u0670 \u0645\u0650\u0646\u06e2 \u0628\u064e\u0639\u0