{"n":91,"na":"الشمس","nl":"Asy-Syams","tt":"Mekah","ja":15,"ay":[{"n":1,"a":"وَالشَّمْسِ وَضُحٰىهَاۖ"},{"n":2,"a":"وَالْقَمَرِ اِذَا تَلٰىهَاۖ"},{"n":3,"a":"وَالنَّهَارِ اِذَا جَلّٰىهَاۖ"},{"n":4,"a":"وَالَّيْلِ اِذَا يَغْشٰىهَاۖ"},{"n":5,"a":"وَالسَّمَاۤءِ وَمَا بَنٰىهَاۖ"},{"n":6,"a":"وَالْاَرْضِ وَمَا طَحٰىهَاۖ"},{"n":7,"a":"وَنَفْسٍ وَّمَا سَوّٰىهَاۖ"},{"n":8,"a":"فَاَلْهَمَهَا فُجُوْرَهَا وَتَقْوٰىهَاۖ"},{"n":9,"a":"قَدْ اَفْلَحَ مَنْ زَكّٰىهَاۖ"},{"n":10,"a":"وَقَدْ خَابَ مَنْ دَسّٰىهَاۗ"},{"n":11,"a":"كَذَّبَتْ ثَمُوْدُ بِطَغْوٰىهَآ  ۖ"},{"n":12,"a":"اِذِ انْۢبَعَثَ اَشْقٰىهَاۖ"},{"n":13,"a":"فَقَالَ لَهُمْ رَسُوْلُ اللّٰهِ نَاقَةَ اللّٰهِ وَسُقْيٰهَاۗ"},{"n":14,"a":"فَكَذَّبُوْهُ فَعَقَرُوْهَاۖ فَدَمْدَمَ عَلَيْهِمْ رَبُّهُمْ بِذَنْۢبِهِمْ فَسَوّٰىهَاۖ"},{"n":15,"a":"وَلَا يَخَافُ عُقْبٰهَا ࣖ"}]}