[{"s":2,"n":203,"t":"\u06de \u0648\u064e\u0671\u0630\u0652\u0643\u064f\u0631\u064f\u0648\u0627\u06df \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u0641\u0650\u0649\u0653 \u0623\u064e\u064a\u0651\u064e\u0627\u0645\u064d\u06e2 \u0645\u0651\u064e\u0639\u0652\u062f\u064f\u0648\u062f\u064e\u0670\u062a\u064d\u06e2 \u06da \u0641\u064e\u0645\u064e\u0646 \u062a\u064e\u0639\u064e\u062c\u0651\u064e\u0644\u064e \u0641\u0650\u0649 \u064a\u064e\u0648\u0652\u0645\u064e\u064a\u0652\u0646\u0650 \u0641\u064e\u0644\u064e\u0627\u0653 \u0625\u0650\u062b\u0652\u0645\u064e \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650 \u0648\u064e\u0645\u064e\u0646 \u062a\u064e\u0623\u064e\u062e\u0651\u064e\u0631\u064e \u0641\u064e\u0644\u064e\u0627\u0653 \u0625\u0650\u062b\u0652\u0645\u064e \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650 \u06da \u0644\u0650\u0645\u064e\u0646\u0650 \u0671\u062a\u0651\u064e\u0642\u064e\u0649\u0670 \u06d7 \u0648\u064e\u0671\u062a\u0651\u064e\u0642\u064f\u0648\u0627\u06df \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u0648\u064e\u0671\u0639\u0652\u0644\u064e\u0645\u064f\u0648\u0653\u0627\u06df \u0623\u064e\u0646\u0651\u064e\u0643\u064f\u0645\u0652 \u0625\u0650\u0644\u064e\u064a\u0652\u0647\u0650 \u062a\u064f\u062d\u0652\u0634\u064e\u0631\u064f\u0648\u0646\u064e","j":2,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0628\u064e\u0642\u064e\u0631\u064e\u0629\u0650"},{"s":2,"n":204,"t":"\u0648\u064e\u0645\u0650\u0646\u064e \u0671\u0644\u0646\u0651\u064e\u0627\u0633\u0650 \u0645\u064e\u0646 \u064a\u064f\u0639\u0652\u062c\u0650\u0628\u064f\u0643\u064e \u0642\u064e\u0648\u0652\u0644\u064f\u0647\u064f\u06e5 \u0641\u0650\u0649 \u0671\u0644\u0652\u062d\u064e\u064a\u064e\u0648\u0670\u0629\u0650 \u0671\u0644\u062f\u0651\u064f\u0646\u0652\u064a\u064e\u0627 \u0648\u064e\u064a\u064f\u0634\u0652\u0647\u0650\u062f\u064f \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u0639\u064e\u0644\u064e\u0649\u0670 \u0645\u064e\u0627 \u0641\u0650\u0649 \u0642\u064e\u0644\u0652\u0628\u0650\u06