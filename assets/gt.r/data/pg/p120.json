[{"s":5,"n":71,"t":"\u0648\u064e\u062d\u064e\u0633\u0650\u0628\u064f\u0648\u0653\u0627\u06df \u0623\u064e\u0644\u0651\u064e\u0627 \u062a\u064e\u0643\u064f\u0648\u0646\u064e \u0641\u0650\u062a\u0652\u0646\u064e\u0629\u064c\u06ed \u0641\u064e\u0639\u064e\u0645\u064f\u0648\u0627\u06df \u0648\u064e\u0635\u064e\u0645\u0651\u064f\u0648\u0627\u06df \u062b\u064f\u0645\u0651\u064e \u062a\u064e\u0627\u0628\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650\u0645\u0652 \u062b\u064f\u0645\u0651\u064e \u0639\u064e\u0645\u064f\u0648\u0627\u06df \u0648\u064e\u0635\u064e\u0645\u0651\u064f\u0648\u0627\u06df \u0643\u064e\u062b\u0650\u064a\u0631\u064c\u06ed \u0645\u0651\u0650\u0646\u0652\u0647\u064f\u0645\u0652 \u06da \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0628\u064e\u0635\u0650\u064a\u0631\u064c\u06e2 \u0628\u0650\u0645\u064e\u0627 \u064a\u064e\u0639\u0652\u0645\u064e\u0644\u064f\u0648\u0646\u064e","j":6,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0645\u064e\u0627\u0626\u0640\u0650\u062f\u064e\u0629\u0650"},{"s":5,"n":72,"t":"\u0644\u064e\u0642\u064e\u062f\u0652 \u0643\u064e\u0641\u064e\u0631\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0642\u064e\u0627\u0644\u064f\u0648\u0653\u0627\u06df \u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u0647\u064f\u0648\u064e \u0671\u0644\u0652\u0645\u064e\u0633\u0650\u064a\u062d\u064f \u0671\u0628\u0652\u0646\u064f \u0645\u064e\u0631\u0652\u064a\u064e\u0645\u064e \u06d6 \u0648\u064e\u0642\u064e\u0627\u0644\u064e \u0671\u0644\u0652\u0645\u064e\u0633\u0650\u064a\u062d\u064f \u064a\u064e\u0670\u0628\u064e\u0646\u0650\u0649\u0653 \u0625\u0650\u0633\u0652\u0631\u064e\u0670\u0653\u0621\u0650\u064a\u0644\u064e \u0671\u0639\u0652\u0628\u064f\u062f\u064f\u0648\u0627\u06df \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u0631\u064e\u0628\u0651\u0650\u0649 \u0648\u064e\u0631\u064e\u0628\u0651\u064e\u0643\u064f\u0645\u0652 \u06d6 \u0625\u0650\u0646\u0651\u064e\u0647\u064f\u06e5 \u0645\u064e\u0646 \u064a\u064f\u0634\u0652\u0631\u0650\u0643\u0652 \u0628\u0650\u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0641\u064e\u0642\u064e\u062f\u0652 \u062d\u064e\u0631\u0651\u064e\u0645\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064f \u0639\u064e\u0644\u064e\u064a\u0652\u0647\u0650 \u0671\u0644\u0652\u062c\u064e\u0646\u0651\u064e\u0629\u064e \u0648\u064e\u0645\u064e\u0623\u0652\u0648\u064e\u0649\u0670\u0647\u064f \u0671\u0644\u0646\u0651\u064e\u0627\u0631\u064f \u06d6 \u0648\u064e\u0645\u064e\u0627 \u0644\u0650\u0644\u0638\u0651\u064e\u0670\u0644\u0650\u0645\u0650\u064a\u0646\u064e \u0645\u0650\u0646\u0652 \u0623\u064e\u0646\u0635\u064e\u0627\u0631\u064d\u06e2","j":6},{"s":5,"n":73,"t":"\u0644\u0651\u064e\u0642\u064e\u062f\u0652 \u0643\u064e\u0641\u064e\u0631\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0642\u064e\u0627\u0644\u064f\u0648\u0653\u0627\u06df \u0625\u0650\u0646\u0651\u064e \u0671\u0644\u0644\u0651\u064e\u0647\u064e \u062b\u064e\u0627\u0644\u0650\u062b\u064f \u062b\u064e\u0644\u064e\u0670\u062b\u064e\u0629\u064d\u06e2 \u06d8 \u0648\u064e\u0645\u064e\u0627 \u0645\u0650\u0646\u0652 \u0625\u0650\u0644\u064e\u0670\u0647\u064d \u0625\u0650\u0644\u0651\u064e\u0627\u0653 \u0625\u0650\u0644\u064e\u0670\u0647\u064c\u06ed \u0648\u064e\u0670\u062d\u0650\u062f\u064c\u06ed \u06da \u0648\u064e\u0625\u0650\u0646 \u0644\u0651\u064e\u0645\u0652 \u064a\u064e\u0646\u062a\u064e\u0647\u064f\u0648\u0627\u06df \u0639\u064e\u0645\u0651\u064e\u0627 \u064a\u064e\u0642\u064f\u0648\u0644\u064f\u0648\u0646\u064e \u0644\u064e\u064a\u064e\u0645\u064e\u0633\u0651\u064e\u0646\u0651\u064e \u0671\u0644\u0651\u064e\u0630\u0650\u064a\u0646\u064e \u0643\u064e\u0641\u064e\u0631\u064f\u0648\u0627\u06df \u0645\u0650\u0646\u0652\u0647\u064f\u0645\u0652 \u0639\u064e\u0630\u064e\u0627\u0628\u064c \u0623\u064e\u0644\u0650\u064a\u0645\u064c","j":6},{"s":5,"n":74,"t":"\u0623\u064e\u0641\u064e\u0644\u064e\u0627 \u064a\u064e\u062a\u064f\u0648\u0628\u064f\u0648\u0646\u064e \u0625\u0650\u0644\u064e\u0649 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0648\u064e\u064a\u064e\u0633\u0652\u062a\u064e\u063a\u0652\u0641\u0650\u0631\u064f\u0648\u0646\u064e\u0647\u064f\u06e5 \u06da \u0648\u064e\u0671\u0644\u0644\u0651\u064e\u0647\u064f \u063a\u064e\u0641\u064f\u0648\u0631\u064c\u06ed \u0631\u0651\u064e\u062d\u0650\u064a\u0645\u064c\u06ed","j":6},{"s":5,"n":75,"t":"\u0645\u0651\u064e\u0627 \u0671\u0644\u0652\u0645\u064e\u0633\u0650\u064a\u062d\u064f \u0671\u0628\u0652\u0646\u064f \u0645\u064e\u0631\u0652\u064a\u064e\u0645\u064e \u0625\u0650\u0644\u0651\u064e\u0627 \u0631\u064e\u0633\u064f\u0648\u0644\u064c\u06ed \u0642\u064e\u062f\u0652 \u062e\u064e\u0644\u064e\u062a\u0652 \u0645\u0650\u0646 \u0642\u064e\u0628\u0652\u0644\u0650\u0647\u0650 \u0671\u0644\u0631\u0651\u064f\u0633\u064f\u0644\u064f \u0648\u064e\u0623\u064f\u0645\u0651\u064f\u0647\u064f\u06e5 \u0635\u0650\u062f\u0651\u0650\u064a\u0642\u064e\u0629\u064c\u06ed \u06d6 \u0643\u064e\u0627\u0646\u064e\u0627 \u064a\u064e\u0623\u0652\u0643\u064f\u0644\u064e\u0627\u0646\u0650 \u0671\u0644\u0637\u0651\u064e\u0639\u064e\u0627\u0645\u064e \u06d7 \u0671\u0646\u0638\u064f\u0631\u0652 \u0643\u064e\u064a\u0652\u0641\u064e \u0646\u064f\u0628\u064e\u064a\u0651\u0650\u0646\u064f \u0644\u064e\u0647\u064f\u0645\u064f \u0671\u0644\u0652\u0621\u064e\u0627\u064a\u064e\u0670\u062a\u0650 \u062b\u064f\u0645\u0651\u064e \u0671\u0646\u0638\u064f\u0631\u0652 \u0623\u064e\u0646\u0651\u064e\u0649\u0670 \u064a\u064f\u0624\u0652\u0641\u064e\u0643\u064f\u0648\u0646\u064e","j":6},{"s":5,"n":76,"t":"\u0642\u064f\u0644\u0652 \u0623\u064e\u062a\u064e\u0639\u0652\u0628\u064f\u062f\u064f\u0648\u0646\u064e \u0645\u0650\u0646 \u062f\u064f\u0648\u0646\u0650 \u0671\u0644\u0644\u0651\u064e\u0647\u0650 \u0645\u064e\u0627 \u0644\u064e\u0627 \u064a\u064e\u0645\u0652\u0644\u0650\u0643\u064f \u0644\u064e\u0643\u064f\u0645\u0652 \u0636\u064e\u0631\u0651\u064b\u06ed\u0627 \u0648\u064e\u0644\u064e\