[{"s":2,"n":127,"t":"\u0648\u064e\u0625\u0650\u0630\u0652 \u064a\u064e\u0631\u0652\u0641\u064e\u0639\u064f \u0625\u0650\u0628\u0652\u0631\u064e\u0670\u0647\u0650\u06e6\u0645\u064f \u0671\u0644\u0652\u0642\u064e\u0648\u064e\u0627\u0639\u0650\u062f\u064e \u0645\u0650\u0646\u064e \u0671\u0644\u0652\u0628\u064e\u064a\u0652\u062a\u0650 \u0648\u064e\u0625\u0650\u0633\u0652\u0645\u064e\u0670\u0639\u0650\u064a\u0644\u064f \u0631\u064e\u0628\u0651\u064e\u0646\u064e\u0627 \u062a\u064e\u0642\u064e\u0628\u0651\u064e\u0644\u0652 \u0645\u0650\u0646\u0651\u064e\u0627\u0653 \u06d6 \u0625\u0650\u0646\u0651\u064e\u0643\u064e \u0623\u064e\u0646\u062a\u064e \u0671\u0644\u0633\u0651\u064e\u0645\u0650\u064a\u0639\u064f \u0671\u0644\u0652\u0639\u064e\u0644\u0650\u064a\u0645\u064f","j":1,"ar":"\u0633\u064f\u0648\u0631\u064e\u0629\u064f \u0627\u0644\u0628\u064e\u0642\u064e\u0631\u064e\u0629\u0650"},{"s":2,"n":128,"t":"\u0631\u064e\u0628\u0651\u064e\u0646\u064e\u0627 \u0648\u064e\u0671\u062c\u0652\u0639\u064e\u0644\u0652\u0646\u064e\u0627 \u0645\u064f\u0633\u0652\u0644\u0650\u0645\u064e\u064a\u0652\u0646\u0650 \u0644\u064e\u0643\u064e \u0648\u064e\u0645\u0650\u0646 \u0630\u064f\u0631\u0651\u0650\u064a\u0651\u064e\u062a\u0650\u0646\u064e\u0627\u0653 \u0623\u064f\u0645\u0651\u064e\u0629\u064b\u06ed \u0645\u0651\u064f\u0633\u0652\u0644\u0650\u0645\u064e\u0629\u064b\u06ed \u0644\u0651\u064e\u0643\u064e \u0648\u064e\u0623\u064e\u0631\u0650\u0646\u064e\u0627 \u0645\u064e\u0646\u064e\u0627\u0633\u0650\u0643\u064e\u0646\u064e\u0627 \u0648\u064e\u062a\u064f\u0628\u0652 \u0639\u064e\u0644\u064e\u064a\u0652\u0646\u064e\u0627\u0653 \u06d6 \u0625\u0650\u0646\u0651\u064e\u0643\u064e \u0623\u064e\u0646\u062a\u064e \u0671\u0644\u062a\u0651\u064e\u0648\u0651\u064e\u0627\u0628\u064f \u0671\u0644\u0631\u0651\u064e\u062d\u0650\u064a\u0645\u064f","j":1},{"s":2,"n":129,"t":"\u0631\u064e\u0628\u0651\u064e\u0646\u064e\u0627 \u0648\u064e\u0671\u0628\u0652\u0639\u064e\u062b\u0652 \u0641\u0650\u064a\u0647\u0650\u0645\